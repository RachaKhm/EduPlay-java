<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.eduplay.controllers.LibraryIndexController"
      style="-fx-background-color: #f1f5f9;"
      spacing="0">

    <!-- HEADER GRADIENT -->
    <HBox style="-fx-background-color: linear-gradient(to right, #3b82f6, #6366f1);
                 -fx-padding: 28 32 28 32;"
          alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="📚 Gestion des Bibliothèques"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Explorez, recherchez et gérez votre collection"
                   style="-fx-font-size: 13px; -fx-text-fill: #bfdbfe;"/>
        </VBox>
        <Button text="＋  Nouvelle Bibliothèque"
                onAction="#handleNouveauLivre"
                style="-fx-background-color: white; -fx-text-fill: #2563eb;
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-background-radius: 12; -fx-padding: 12 22;
                       -fx-cursor: hand;"/>
    </HBox>

    <!-- BARRE DE RECHERCHE -->
    <HBox style="-fx-background-color: white; -fx-padding: 16 32; -fx-border-color: #e2e8f0;
                 -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="12">
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher par nom, thème..."
                   style="-fx-background-radius: 10; -fx-border-radius: 10;
                          -fx-border-color: #cbd5e1; -fx-border-width: 2;
                          -fx-padding: 9 14; -fx-font-size: 13px;"
                   prefWidth="280"/>
        <ComboBox fx:id="filterLevel" promptText="Niveau"
                  style="-fx-background-radius: 10; -fx-font-size: 13px; -fx-padding: 4 8;"
                  prefWidth="140"/>
        <TextField fx:id="filterTheme"
                   promptText="Thème..."
                   style="-fx-background-radius: 10; -fx-border-radius: 10;
                          -fx-border-color: #cbd5e1; -fx-border-width: 2;
                          -fx-padding: 9 14; -fx-font-size: 13px;"
                   prefWidth="160"/>
        <Button text="Rechercher" onAction="#handleSearch"
                style="-fx-background-color: linear-gradient(to right,#3b82f6,#6366f1);
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 10; -fx-padding: 9 20; -fx-cursor: hand;"/>
        <Button text="Réinitialiser" onAction="#handleReset"
                style="-fx-background-color: white; -fx-text-fill: #64748b;
                       -fx-border-color: #cbd5e1; -fx-border-width: 2;
                       -fx-background-radius: 10; -fx-padding: 9 16; -fx-cursor: hand;"/>
        <HBox.margin>
            <Insets/>
        </HBox.margin>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel"
               style="-fx-background-color: #f0fdf4; -fx-text-fill: #15803d;
                      -fx-font-weight: bold; -fx-font-size: 13px;
                      -fx-background-radius: 8; -fx-padding: 6 14;
                      -fx-border-color: #bbf7d0; -fx-border-width: 1; -fx-border-radius: 8;"/>
    </HBox>

    <!-- FLASH MESSAGE -->
    <HBox fx:id="flashBox"
          style="-fx-background-color: #f0fdf4; -fx-padding: 10 32;
                 -fx-border-color: #22c55e; -fx-border-width: 0 0 0 4;"
          alignment="CENTER_LEFT" spacing="10" managed="false" visible="false">
        <Label text="✅"/>
        <Label fx:id="flashLabel"
               style="-fx-text-fill: #15803d; -fx-font-weight: bold; -fx-font-size: 13px;"/>
    </HBox>

    <!-- SCROLL AVEC LES CARTES -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: #f1f5f9;">
        <VBox style="-fx-padding: 24 32;">
            <!-- GRILLE DES CARTES -->
            <FlowPane fx:id="cardsPane"
                      hgap="24" vgap="24"
                      style="-fx-background-color: transparent;"/>

            <!-- ÉTAT VIDE -->
            <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
                  style="-fx-padding: 80 0;" managed="false" visible="false">
                <Label text="📖"
                       style="-fx-font-size: 64px;"/>
                <Label text="Aucune Bibliothèque disponible"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <Label text="Commencez à enrichir votre collection en créant votre première bibliothèque."
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280; -fx-text-alignment: center;"/>
                <Button text="＋  Créer une Bibliothèque" onAction="#handleNouveauLivre"
                        style="-fx-background-color: linear-gradient(to right,#3b82f6,#6366f1);
                               -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </ScrollPane>

</VBox>
