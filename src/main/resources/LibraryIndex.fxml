<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>

<ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.eduplay.controllers.LibraryIndexController">
    <VBox spacing="24" style="-fx-padding: 30; -fx-background-color: #F8FAFC;">
        
        <!-- HEADER AVEC BACKGROUND GRADIENT -->
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: linear-gradient(to right, #6366F1, #9333EA); -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
            <VBox HBox.hgrow="ALWAYS" spacing="8">
                <Label text="📚 Gestion des Bibliothèques" style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;"/>
                <Label text="Explorez, recherchez et gérez votre collection" style="-fx-text-fill: #E0E7FF; -fx-font-size: 16px;"/>
            </VBox>
            
            <HBox spacing="16">
                <!-- Bouton Ajouter -->
                <Button text="＋ Nouvelle Bibliothèque" onAction="#handleNouveauLivre" 
                        style="-fx-background-color: white; -fx-text-fill: #4F46E5; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 12 24; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
            </HBox>
        </HBox>

        <!-- FLASH MESSAGE -->
        <HBox fx:id="flashBox" style="-fx-background-color: #f0fdf4; -fx-padding: 10 24; -fx-border-radius: 12; -fx-background-radius: 12; -fx-border-color: #22c55e; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);" alignment="CENTER_LEFT" spacing="10" managed="false" visible="false">
            <Label text="✅" style="-fx-font-size: 16px;"/>
            <Label fx:id="flashLabel" style="-fx-text-fill: #15803d; -fx-font-weight: bold; -fx-font-size: 14px;"/>
        </HBox>

        <!-- FILTRES & RECHERCHE -->
        <VBox spacing="20" style="-fx-background-color: white; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 24; -fx-border-color: #F1F5F9; -fx-border-width: 2; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            
            <HBox spacing="16" alignment="CENTER_LEFT">
                <HBox style="-fx-background-color: #EEF2FF; -fx-background-radius: 12; -fx-padding: 10;" alignment="CENTER">
                    <Label text="🔍" style="-fx-font-size: 20px;"/>
                </HBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Filtres de Recherche" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
                    <Label text="Trouvez rapidement la bibliothèque que vous cherchez" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <Separator style="-fx-background-color: #F8FAFC; -fx-padding: 10 0;"/>

            <VBox spacing="16">
                <!-- Filters -->
                <HBox spacing="16">
                    <TextField fx:id="searchField" promptText="🔍 Rechercher par nom, thème..." HBox.hgrow="ALWAYS" style="-fx-padding: 12; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-color: white;"/>
                    <ComboBox fx:id="filterLevel" promptText="Niveau" prefWidth="140" style="-fx-padding: 6; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-color: white;"/>
                    <TextField fx:id="filterTheme" promptText="Thème..." prefWidth="160" style="-fx-padding: 12; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12; -fx-background-color: white;"/>
                    <Button text="Rechercher" onAction="#handleSearch" style="-fx-background-color: #4F46E5; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
                    <Button text="Réinitialiser" onAction="#handleReset" style="-fx-background-color: white; -fx-text-fill: #64748B; -fx-border-color: #CBD5E1; -fx-border-radius: 12; -fx-border-width: 2; -fx-background-radius: 12; -fx-padding: 10 16; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- HEADER RESSOURCES -->
        <HBox alignment="CENTER_LEFT">
            <Label text="Résultats de votre recherche" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="countLabel" text="0 résultats" style="-fx-background-color: #f0fdf4; -fx-text-fill: #15803d; -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 6 14; -fx-border-color: #bbf7d0; -fx-border-width: 1; -fx-border-radius: 8;"/>
        </HBox>

        <!-- GRILLE DE CARTES -->
        <FlowPane fx:id="cardsPane" hgap="24" vgap="24" alignment="TOP_LEFT" />

        <!-- ÉTAT VIDE -->
        <VBox fx:id="emptyState" alignment="CENTER" spacing="16" style="-fx-padding: 80 0;" managed="false" visible="false">
            <Label text="📖" style="-fx-font-size: 64px;"/>
            <Label text="Aucune Bibliothèque disponible" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <Label text="Commencez à enrichir votre collection en créant votre première bibliothèque." style="-fx-font-size: 13px; -fx-text-fill: #6b7280; -fx-text-alignment: center;"/>
            <Button text="＋ Créer une Bibliothèque" onAction="#handleNouveauLivre" style="-fx-background-color: linear-gradient(to right, #6366F1, #9333EA); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(99,102,241,0.4), 10, 0, 0, 4);"/>
        </VBox>

    </VBox>
</ScrollPane>
