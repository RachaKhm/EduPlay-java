<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<VBox xmlns="http://javafx.com/javafx/20.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.event.StatisticsController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color: #f3f4f6;">

    <padding>
        <Insets top="25" right="35" bottom="25" left="35"/>
    </padding>

    <children>
        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="📊 Statistiques" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Analyse des événements et inscriptions" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
            </VBox>
            <HBox spacing="10">
                <Button text="🔄 Rafraîchir" onAction="#refreshStats"
                        style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                <Button text="← Retour" onAction="#goBack"
                        style="-fx-background-color: #64748b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>
        </HBox>

        <!-- Cartes KPI -->
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>

            <!-- Total événements -->
            <VBox GridPane.columnIndex="0" spacing="5"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="📅 Total événements" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label fx:id="totalEventsLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                <Button text="Voir tout" onAction="#showAllEvents"
                        style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-size: 11px; -fx-padding: 0; -fx-cursor: hand;"/>
            </VBox>

            <!-- Total inscriptions -->
            <VBox GridPane.columnIndex="1" spacing="5"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="📋 Total inscriptions" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label fx:id="totalRegistrationsLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                <Button text="Voir tout" onAction="#showAllRegistrations"
                        style="-fx-background-color: transparent; -fx-text-fill: #10b981; -fx-font-size: 11px; -fx-padding: 0; -fx-cursor: hand;"/>
            </VBox>

            <!-- Événements à venir -->
            <VBox GridPane.columnIndex="2" spacing="5"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="⏰ À venir" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label fx:id="upcomingEventsLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                <Label text="prochains événements" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
            </VBox>

            <!-- Événements passés -->
            <VBox GridPane.columnIndex="3" spacing="5"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="📅 Passés" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label fx:id="pastEventsLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                <Label text="événements terminés" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
            </VBox>
        </GridPane>

        <!-- Deuxième ligne de cartes -->
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <!-- Total participants -->
            <VBox GridPane.columnIndex="0" spacing="5"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="👥 Total participants" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label fx:id="totalParticipantsLabel" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                <Label text="inscriptions cumulées" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
            </VBox>

            <!-- Taux de remplissage -->
            <VBox GridPane.columnIndex="1" spacing="5"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                <Label text="📊 Taux de remplissage" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Label fx:id="fillRateLabel" text="0%" style="-fx-font-size: 32px; -fx-font-weight: bold;"/>
                <Label text="des places occupées" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
            </VBox>
        </GridPane>

        <!-- Graphique des inscriptions -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="📈 Évolution des inscriptions" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 16px;"/>
            <Separator/>
            <BarChart fx:id="registrationsChart" title="Inscriptions par mois"
                      style="-fx-background-color: transparent;" prefHeight="300">
                <xAxis>
                    <CategoryAxis fx:id="xAxis" label="Mois"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="yAxis" label="Nombre d'inscriptions"/>
                </yAxis>
            </BarChart>
        </VBox>

        <!-- Top événements populaires -->
        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
            <Label text="🏆 Événements les plus populaires" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 16px;"/>
            <Separator/>
            <TableView fx:id="topEventsTable" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colEventTitle" text="Événement" prefWidth="200"/>
                    <TableColumn fx:id="colRegistrations" text="Inscrits" prefWidth="80" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colMaxCapacity" text="Capacité" prefWidth="80" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colFillRate" text="Taux (%)" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="colEventDate" text="Date" prefWidth="150" style="-fx-alignment: CENTER;"/>
                </columns>
                <placeholder>
                    <Label text="Aucun événement trouvé" style="-fx-text-fill: #9ca3af;"/>
                </placeholder>
            </TableView>
        </VBox>
    </children>
</VBox>