<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.admin.AdminCalendarController"
      spacing="16" style="-fx-background-color: #F8F9FA; -fx-padding: 0;">

    <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 0 0 8 0;">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Calendrier des séances"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
            <Label fx:id="pageSubtitle" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #9999BB;"/>
        </VBox>

        <Button fx:id="syncGoogleButton" text="Synchroniser Google Calendar"
                style="-fx-background-color:#4A90D9;-fx-text-fill:white;-fx-font-weight:bold;
                       -fx-background-radius:10;-fx-padding:10 16;-fx-cursor:hand;"/>
    </HBox>

    <VBox spacing="10"
          style="-fx-background-color: white; -fx-padding: 14; -fx-background-radius: 12;
                 -fx-border-color: #E9EAF2; -fx-border-radius: 12; -fx-border-width: 1;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Vue mensuelle"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="clearDayFilterButton" text="Effacer sélection"
                    style="-fx-background-color:#F2F4FA;-fx-text-fill:#4B5070;-fx-font-weight:bold;
                           -fx-background-radius:8;-fx-padding:6 10;-fx-cursor:hand;"/>
            <Button fx:id="prevMonthButton" text="◀"
                    style="-fx-background-color:#F2F4FA;-fx-text-fill:#4B5070;-fx-font-weight:bold;
                           -fx-background-radius:8;-fx-padding:6 10;-fx-cursor:hand;"/>
            <Label fx:id="calendarMonthLabel" text="Mois"
                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #55557A;"/>
            <Button fx:id="nextMonthButton" text="▶"
                    style="-fx-background-color:#F2F4FA;-fx-text-fill:#4B5070;-fx-font-weight:bold;
                           -fx-background-radius:8;-fx-padding:6 10;-fx-cursor:hand;"/>
        </HBox>

        <GridPane fx:id="calendarGrid" hgap="8" vgap="8">
            <columnConstraints>
                <ColumnConstraints percentWidth="14.28"/>
                <ColumnConstraints percentWidth="14.28"/>
                <ColumnConstraints percentWidth="14.28"/>
                <ColumnConstraints percentWidth="14.28"/>
                <ColumnConstraints percentWidth="14.28"/>
                <ColumnConstraints percentWidth="14.28"/>
                <ColumnConstraints percentWidth="14.32"/>
            </columnConstraints>
        </GridPane>
    </VBox>

    <VBox spacing="8"
          style="-fx-background-color:white;-fx-padding:14;-fx-background-radius:12;
                 -fx-border-color:#E9EAF2;-fx-border-radius:12;-fx-border-width:1;"
          VBox.vgrow="ALWAYS">
        <Label fx:id="selectedDaySummary" text="Clique une date pour voir les séances du jour."
               style="-fx-font-size: 12px; -fx-text-fill: #777799;"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;">
            <content>
                <VBox fx:id="selectedDaySeancesBox" spacing="8" style="-fx-padding: 2 2 8 2;"/>
            </content>
        </ScrollPane>
    </VBox>

</VBox>
