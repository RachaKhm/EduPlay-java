<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    DashboardView.fxml — Tableau de bord Admin
    ─────────────────────────────────────────────────────────────
    Vue chargée par Router.go("admin_dashboard").
    Injectée dans le StackPane contentArea de MainView.fxml.
    Tous les styles viennent de app.css (styleClass="...").
    AUCUN style inline sauf les overrides de layout inévitables.
    ─────────────────────────────────────────────────────────────
-->
<ScrollPane fitToWidth="true"
            styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.DashboardController">

    <VBox spacing="24" style="-fx-padding: 0 0 28 0;">

        <!-- ═══ EN-TÊTE DE PAGE ═══ -->
        <VBox spacing="4">
            <Label text="Tableau de bord" styleClass="page-title"/>
            <Label text="Vue d'ensemble de la plateforme EduPlay" styleClass="page-subtitle"/>
        </VBox>

        <!-- ═══ CARTES STATISTIQUES ═══ -->
        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>

            <!-- Total utilisateurs -->
            <VBox GridPane.columnIndex="0" spacing="6" styleClass="stat-card">
                <Label text="Total utilisateurs" styleClass="stat-label"/>
                <Label fx:id="totalUsersLabel" text="—" styleClass="stat-value"/>
                <Label text="sur la plateforme"  styleClass="stat-sublabel"/>
            </VBox>

            <!-- Enseignants -->
            <VBox GridPane.columnIndex="1" spacing="6"
                  style="-fx-background-color: #FFF5F7; -fx-padding: 20;
                         -fx-background-radius: 12;
                         -fx-border-color: #F8C8D0; -fx-border-width: 1; -fx-border-radius: 12;">
                <Label text="Enseignants"
                       style="-fx-font-size: 12px; -fx-text-fill: #C0607A;"/>
                <Label fx:id="totalEnseignantsLabel" text="—"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
                <Label text="actifs dans le système"
                       style="-fx-font-size: 11px; -fx-text-fill: #C0607A;"/>
            </VBox>

            <!-- Parents -->
            <VBox GridPane.columnIndex="2" spacing="6"
                  style="-fx-background-color: #F0F5FF; -fx-padding: 20;
                         -fx-background-radius: 12;
                         -fx-border-color: #C0D0F8; -fx-border-width: 1; -fx-border-radius: 12;">
                <Label text="Parents"
                       style="-fx-font-size: 12px; -fx-text-fill: #4060C0;"/>
                <Label fx:id="totalParentsLabel" text="—"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4A90D9;"/>
                <Label text="comptes vérifiés"
                       style="-fx-font-size: 11px; -fx-text-fill: #4060C0;"/>
            </VBox>

            <!-- Enfants -->
            <VBox GridPane.columnIndex="3" spacing="6"
                  style="-fx-background-color: #F4FFF8; -fx-padding: 20;
                         -fx-background-radius: 12;
                         -fx-border-color: #B0E8C8; -fx-border-width: 1; -fx-border-radius: 12;">
                <Label text="Enfants"
                       style="-fx-font-size: 12px; -fx-text-fill: #2E8050;"/>
                <Label fx:id="totalEnfantsLabel" text="—"
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3AB068;"/>
                <Label text="élèves inscrits"
                       style="-fx-font-size: 11px; -fx-text-fill: #2E8050;"/>
            </VBox>
        </GridPane>

        <!-- ═══ DERNIERS INSCRITS ═══ -->
        <VBox styleClass="card" spacing="0">

            <!-- En-tête de la card -->
            <HBox alignment="CENTER_LEFT" styleClass="card-header">
                <Label text="Derniers utilisateurs inscrits" styleClass="card-title"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Voir tous →"
                        onAction="#showUsers"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #4A90D9; -fx-font-size: 12px;
                               -fx-border-width: 0; -fx-cursor: hand;"/>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="recentUsersTable"
                       prefHeight="240"
                       styleClass="table-view"
                       style="-fx-background-color: transparent;">
                <columns>
                    <TableColumn fx:id="recentColName"
                                 text="Nom complet"
                                 prefWidth="200"/>
                    <TableColumn fx:id="recentColEmail"
                                 text="Email"
                                 prefWidth="230"/>
                    <TableColumn fx:id="recentColType"
                                 text="Type"
                                 prefWidth="120"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="recentColDate"
                                 text="Inscrit le"
                                 prefWidth="150"
                                 style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="recentColActive"
                                 text="Statut"
                                 prefWidth="110"
                                 style="-fx-alignment: CENTER;"/>
                </columns>
                <placeholder>
                    <Label text="Aucun utilisateur trouvé."
                           styleClass="stat-sublabel"/>
                </placeholder>
            </TableView>

        </VBox>

    </VBox>
</ScrollPane>
