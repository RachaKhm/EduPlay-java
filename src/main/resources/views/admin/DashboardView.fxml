<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.DashboardController"
            prefWidth="960" prefHeight="640"
            style="-fx-background-color: #F8F9FA;">

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox spacing="0" prefWidth="220"
              style="-fx-background-color: #1A1A2E; -fx-min-height: 640;">

            <!-- Logo -->
            <VBox alignment="CENTER"
                  style="-fx-padding: 28 20 24 20;
                         -fx-border-color: #2A2A4E; -fx-border-width: 0 0 1 0;">
                <Label text="EduPlay"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
                <Label text="Administration"
                       style="-fx-font-size: 11px; -fx-text-fill: #555577;"/>
            </VBox>

            <!-- Navigation -->
            <VBox spacing="4" style="-fx-padding: 16 12 16 12;">

                <Button text="  Tableau de bord"
                        onAction="#showDashboard"
                        maxWidth="Infinity"
                        style="-fx-background-color: #E94560;
                               -fx-text-fill: white; -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT; -fx-padding: 10 16;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-border-width: 0;"/>

                <Button text="  Utilisateurs"
                        onAction="#showUsers"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #AAAACC; -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT; -fx-padding: 10 16;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-border-width: 0;"/>

                <Button text="  Enseignants"
                        onAction="#showTeachers"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #AAAACC; -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT; -fx-padding: 10 16;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-border-width: 0;"/>

                <Button text="  Parents"
                        onAction="#showParents"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #AAAACC; -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT; -fx-padding: 10 16;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-border-width: 0;"/>

                <Button text="  Enfants"
                        onAction="#showChildren"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #AAAACC; -fx-font-size: 13px;
                               -fx-alignment: CENTER_LEFT; -fx-padding: 10 16;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-border-width: 0;"/>
            </VBox>

            <VBox VBox.vgrow="ALWAYS"/>

            <!-- Déconnexion -->
            <VBox style="-fx-padding: 12;
                         -fx-border-color: #2A2A4E; -fx-border-width: 1 0 0 0;">
                <Button text="  Déconnexion"
                        onAction="#logout"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #666688; -fx-font-size: 12px;
                               -fx-alignment: CENTER_LEFT; -fx-padding: 8 16;
                               -fx-background-radius: 6; -fx-cursor: hand;
                               -fx-border-width: 0;"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===== MAIN CONTENT ===== -->
    <center>
        <VBox spacing="0">

            <!-- Top bar -->
            <HBox alignment="CENTER_LEFT"
                  style="-fx-padding: 16 28;
                         -fx-background-color: white;
                         -fx-border-color: #E8E8F0; -fx-border-width: 0 0 1 0;">
                <Label text="Tableau de bord"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Label fx:id="adminNameLabel"
                       text="Administrateur"
                       style="-fx-font-size: 13px; -fx-text-fill: #9999BB;"/>
            </HBox>

            <!-- Scroll zone -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: #F8F9FA;">
                <VBox spacing="24" style="-fx-padding: 28;">

                    <!-- ===== CARTES STATS ===== -->
                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                            <ColumnConstraints percentWidth="25"/>
                        </columnConstraints>

                        <!-- Total users -->
                        <VBox GridPane.columnIndex="0" spacing="6"
                              style="-fx-background-color: white; -fx-padding: 20;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #E8E8F0; -fx-border-width: 1;
                                     -fx-border-radius: 10;">
                            <Label text="Total utilisateurs"
                                   style="-fx-font-size: 12px; -fx-text-fill: #9999BB;"/>
                            <Label fx:id="totalUsersLabel" text="—"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
                            <Label fx:id="totalTrendLabel" text=""
                                   style="-fx-font-size: 11px; -fx-text-fill: #4CAF9A;"/>
                        </VBox>

                        <!-- Enseignants -->
                        <VBox GridPane.columnIndex="1" spacing="6"
                              style="-fx-background-color: #FFF5F7; -fx-padding: 20;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #F8C8D0; -fx-border-width: 1;
                                     -fx-border-radius: 10;">
                            <Label text="Enseignants"
                                   style="-fx-font-size: 12px; -fx-text-fill: #C0607A;"/>
                            <Label fx:id="totalEnseignantsLabel" text="—"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
                            <Label text="actifs dans le système"
                                   style="-fx-font-size: 11px; -fx-text-fill: #C0607A;"/>
                        </VBox>

                        <!-- Parents -->
                        <VBox GridPane.columnIndex="2" spacing="6"
                              style="-fx-background-color: #F0F5FF; -fx-padding: 20;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #C0D0F8; -fx-border-width: 1;
                                     -fx-border-radius: 10;">
                            <Label text="Parents"
                                   style="-fx-font-size: 12px; -fx-text-fill: #4060C0;"/>
                            <Label fx:id="totalParentsLabel" text="—"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4A90D9;"/>
                            <Label text="comptes vérifiés"
                                   style="-fx-font-size: 11px; -fx-text-fill: #4060C0;"/>
                        </VBox>

                        <!-- Enfants -->
                        <VBox GridPane.columnIndex="3" spacing="6"
                              style="-fx-background-color: #F4FFF8; -fx-padding: 20;
                                     -fx-background-radius: 10;
                                     -fx-border-color: #B0E8C8; -fx-border-width: 1;
                                     -fx-border-radius: 10;">
                            <Label text="Enfants"
                                   style="-fx-font-size: 12px; -fx-text-fill: #2E8050;"/>
                            <Label fx:id="totalEnfantsLabel" text="—"
                                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #3AB068;"/>
                            <Label text="élèves inscrits"
                                   style="-fx-font-size: 11px; -fx-text-fill: #2E8050;"/>
                        </VBox>
                    </GridPane>

                    <!-- ===== DERNIERS INSCRITS ===== -->
                    <VBox spacing="0"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 10;
                                 -fx-border-color: #E8E8F0; -fx-border-width: 1;
                                 -fx-border-radius: 10;">

                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding: 16 20;
                                     -fx-border-color: #F0F0F8; -fx-border-width: 0 0 1 0;">
                            <Label text="Derniers utilisateurs inscrits"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
                            <HBox HBox.hgrow="ALWAYS"/>
                            <Button text="Voir tous →"
                                    onAction="#showUsers"
                                    style="-fx-background-color: transparent;
                                           -fx-text-fill: #4A90D9; -fx-font-size: 12px;
                                           -fx-border-width: 0; -fx-cursor: hand;"/>
                        </HBox>

                        <TableView fx:id="recentUsersTable"
                                   prefHeight="220"
                                   style="-fx-background-color: transparent;
                                          -fx-table-cell-border-color: #F4F4FA;
                                          -fx-font-size: 13px;">
                            <columns>
                                <TableColumn fx:id="recentColName"   text="Nom complet" prefWidth="200"/>
                                <TableColumn fx:id="recentColEmail"  text="Email"        prefWidth="230"/>
                                <TableColumn fx:id="recentColType"   text="Type"         prefWidth="110" style="-fx-alignment: CENTER;"/>
                                <TableColumn fx:id="recentColDate"   text="Inscrit le"   prefWidth="140" style="-fx-alignment: CENTER;"/>
                                <TableColumn fx:id="recentColActive" text="Statut"       prefWidth="100" style="-fx-alignment: CENTER;"/>
                            </columns>
                            <placeholder>
                                <Label text="Chargement..."
                                       style="-fx-font-size: 13px; -fx-text-fill: #AAAACC;"/>
                            </placeholder>
                        </TableView>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
