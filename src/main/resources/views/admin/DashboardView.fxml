<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    DashboardView.fxml — Tableau de bord Admin
    ─────────────────────────────────────────────────────────────
    Vue chargée par Router.go("admin_dashboard").
    Injectée dans le StackPane contentArea de MainView.fxml.
    Tous les styles viennent de app.css (styleClass="...").
    AUCUN style inline sauf les overrides de layout inévitables.
    ─────────────────────────────────────────────────────────────
-->
<ScrollPane fitToWidth="true"
            styleClass="scroll-pane, admin-scroll-pane"
            stylesheets="@../../styles/admin.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.DashboardController">

    <VBox spacing="24" styleClass="admin-page-header">

        <!-- ═══ EN-TÊTE DE PAGE ═══ -->
        <VBox spacing="4">
            <Label text="Tableau de bord" styleClass="page-title"/>
            <Label text="Vue d'ensemble de la plateforme EduPlay" styleClass="page-subtitle"/>
        </VBox>

        <!-- ═══ CARTES STATISTIQUES ═══ -->
        <GridPane hgap="24" vgap="24">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
            </columnConstraints>

            <!-- Total utilisateurs -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="12" styleClass="stat-card, admin-stat-card-total">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="👤" style="-fx-font-size: 24px;"/>
                    <Label text="Utilisateurs" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="totalUsersLabel" text="—" styleClass="stat-value"/>
                <Label text="Inscriptions totales"  styleClass="stat-sublabel"/>
            </VBox>

            <!-- Enseignants -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="12" styleClass="stat-card, admin-stat-card-teachers">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="👨‍🏫" style="-fx-font-size: 24px;"/>
                    <Label text="Enseignants" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="totalEnseignantsLabel" text="—" styleClass="stat-value"/>
                <Label text="Membres du corps professoral" styleClass="stat-sublabel"/>
            </VBox>

            <!-- Parents -->
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="12" styleClass="stat-card, admin-stat-card-parents">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="👪" style="-fx-font-size: 24px;"/>
                    <Label text="Parents" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="totalParentsLabel" text="—" styleClass="stat-value"/>
                <Label text="Comptes familles actifs" styleClass="stat-sublabel"/>
            </VBox>

            <!-- Enfants -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="12" styleClass="stat-card, admin-stat-card-children">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="👶" style="-fx-font-size: 24px;"/>
                    <Label text="Enfants" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="totalEnfantsLabel" text="—" styleClass="stat-value"/>
                <Label text="Élèves inscrits" styleClass="stat-sublabel"/>
            </VBox>

            <!-- Cours -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="12" styleClass="stat-card, admin-stat-card-courses">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📚" style="-fx-font-size: 24px;"/>
                    <Label text="Cours" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="totalCoursesLabel" text="—" styleClass="stat-value"/>
                <Label text="Modules d'apprentissage" styleClass="stat-sublabel"/>
            </VBox>

            <!-- Séances -->
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="1" spacing="12" styleClass="stat-card, admin-stat-card-seances">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🗓️" style="-fx-font-size: 24px;"/>
                    <Label text="Séances" styleClass="stat-label"/>
                </HBox>
                <Label fx:id="totalSeancesLabel" text="—" styleClass="stat-value"/>
                <Label text="Sessions programmées" styleClass="stat-sublabel"/>
            </VBox>
        </GridPane>

        <!-- ═══ DERNIERS INSCRITS ═══ -->
        <VBox styleClass="card" spacing="0">

            <!-- En-tête de la card -->
            <HBox alignment="CENTER_LEFT" styleClass="card-header">
                <Label text="Derniers utilisateurs inscrits" styleClass="card-title"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Voir tous →"
                        onAction="#showUsers"
                        styleClass="admin-card-action-btn"/>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="recentUsersTable"
                       prefHeight="240"
                       styleClass="table-view, admin-table-view">
                <columns>
                    <TableColumn fx:id="recentColName"
                                 text="Nom complet"
                                 prefWidth="200"/>
                    <TableColumn fx:id="recentColEmail"
                                 text="Email"
                                 prefWidth="230"/>
                    <TableColumn fx:id="recentColType"
                                 text="Type"
                                 prefWidth="120"
                                 styleClass="admin-table-cell-center"/>
                    <TableColumn fx:id="recentColDate"
                                 text="Inscrit le"
                                 prefWidth="150"
                                 styleClass="admin-table-cell-center"/>
                    <TableColumn fx:id="recentColActive"
                                 text="Statut"
                                 prefWidth="110"
                                 styleClass="admin-table-cell-center"/>
                </columns>
                <placeholder>
                    <Label text="Aucun utilisateur trouvé."
                           styleClass="stat-sublabel"/>
                </placeholder>
            </TableView>

        </VBox>

    </VBox>
</ScrollPane>