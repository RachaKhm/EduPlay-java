<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
    DashboardView.fxml — Tableau de bord Admin
    ─────────────────────────────────────────────────────────────
    Vue chargée par Router.go("admin_dashboard").
    Injectée dans le StackPane contentArea de MainView.fxml.
    Tous les styles viennent de app.css (styleClass="...").
    AUCUN style inline sauf les overrides de layout inévitables.
    ─────────────────────────────────────────────────────────────
-->
<ScrollPane fitToWidth="true"
            styleClass="scroll-pane, admin-scroll-pane"
            stylesheets="@../../styles/admin.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.DashboardController">

    <VBox spacing="24" styleClass="admin-page-header">

        <!-- ═══ EN-TÊTE DE PAGE ═══ -->
        <VBox spacing="4">
            <Label text="Tableau de bord" styleClass="page-title"/>
            <Label text="Vue d'ensemble de la plateforme EduPlay" styleClass="page-subtitle"/>
        </VBox>

        <!-- ═══ CARTES STATISTIQUES ═══ -->
        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
            </columnConstraints>

            <!-- Total utilisateurs -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="6" styleClass="stat-card">
                <Label text="Total utilisateurs" styleClass="stat-label"/>
                <Label fx:id="totalUsersLabel" text="—" styleClass="stat-value"/>
                <Label text="sur la plateforme"  styleClass="stat-sublabel"/>
            </VBox>

            <!-- Enseignants -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="6"
                  styleClass="admin-stat-card-teachers">
                <Label text="Enseignants"
                       styleClass="admin-stat-label-teachers"/>
                <Label fx:id="totalEnseignantsLabel" text="—"
                       styleClass="admin-stat-value-teachers"/>
                <Label text="actifs dans le système"
                       styleClass="admin-stat-label-teachers" style="-fx-font-size: 11px;"/>
            </VBox>

            <!-- Parents -->
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="0" spacing="6"
                  styleClass="admin-stat-card-parents">
                <Label text="Parents"
                       styleClass="admin-stat-label-parents"/>
                <Label fx:id="totalParentsLabel" text="—"
                       styleClass="admin-stat-value-parents"/>
                <Label text="comptes vérifiés"
                       styleClass="admin-stat-label-parents" style="-fx-font-size: 11px;"/>
            </VBox>

            <!-- Enfants -->
            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="6"
                  styleClass="admin-stat-card-children">
                <Label text="Enfants"
                       styleClass="admin-stat-label-children"/>
                <Label fx:id="totalEnfantsLabel" text="—"
                       styleClass="admin-stat-value-children"/>
                <Label text="élèves inscrits"
                       styleClass="admin-stat-label-children" style="-fx-font-size: 11px;"/>
            </VBox>

            <!-- Cours -->
            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="6"
                  styleClass="stat-card">
                <Label text="Cours"
                       styleClass="stat-label"/>
                <Label fx:id="totalCoursesLabel" text="—"
                       styleClass="stat-value" style="-fx-text-fill: #8E24AA;"/>
                <Label text="créés"
                       styleClass="stat-sublabel"/>
            </VBox>

            <!-- Séances -->
            <VBox GridPane.columnIndex="2" GridPane.rowIndex="1" spacing="6"
                  styleClass="stat-card">
                <Label text="Séances"
                       styleClass="stat-label"/>
                <Label fx:id="totalSeancesLabel" text="—"
                       styleClass="stat-value" style="-fx-text-fill: #F4511E;"/>
                <Label text="planifiées"
                       styleClass="stat-sublabel"/>
            </VBox>
        </GridPane>

        <!-- ═══ DERNIERS INSCRITS ═══ -->
        <VBox styleClass="card" spacing="0">

            <!-- En-tête de la card -->
            <HBox alignment="CENTER_LEFT" styleClass="card-header">
                <Label text="Derniers utilisateurs inscrits" styleClass="card-title"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="Voir tous →"
                        onAction="#showUsers"
                        styleClass="admin-card-action-btn"/>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="recentUsersTable"
                       prefHeight="240"
                       styleClass="table-view, admin-table-view">
                <columns>
                    <TableColumn fx:id="recentColName"
                                 text="Nom complet"
                                 prefWidth="200"/>
                    <TableColumn fx:id="recentColEmail"
                                 text="Email"
                                 prefWidth="230"/>
                    <TableColumn fx:id="recentColType"
                                 text="Type"
                                 prefWidth="120"
                                 styleClass="admin-table-cell-center"/>
                    <TableColumn fx:id="recentColDate"
                                 text="Inscrit le"
                                 prefWidth="150"
                                 styleClass="admin-table-cell-center"/>
                    <TableColumn fx:id="recentColActive"
                                 text="Statut"
                                 prefWidth="110"
                                 styleClass="admin-table-cell-center"/>
                </columns>
                <placeholder>
                    <Label text="Aucun utilisateur trouvé."
                           styleClass="stat-sublabel"/>
                </placeholder>
            </TableView>

        </VBox>

    </VBox>
</ScrollPane>
