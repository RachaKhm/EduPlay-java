<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.UserListController"
            stylesheets="@../../styles/admin.css"
            styleClass="admin-scroll-pane">

    <!-- ===== HEADER ===== -->
    <top>
        <VBox styleClass="admin-header-bg">
            <HBox alignment="CENTER_LEFT" spacing="16"
                  styleClass="admin-header-container">
                <Label text="EduPlay"
                       styleClass="sidebar-brand-edu" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
                <Label text="›"
                       styleClass="admin-breadcrumb-separator"/>
                <Label text="Gestion des utilisateurs"
                       styleClass="admin-breadcrumb-text, admin-breadcrumb-text-active"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button text="+ Nouvel utilisateur"
                        onAction="#openAddUserForm"
                        styleClass="admin-btn-primary-small"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===== CONTENT ===== -->
    <center>
        <VBox spacing="0">

            <!-- Barre filtres -->
            <HBox spacing="12" alignment="CENTER_LEFT"
                  styleClass="admin-filter-bar">

                <!-- Recherche -->
                <TextField fx:id="searchField"
                           promptText="Rechercher par nom, prénom, email..."
                           onKeyReleased="#search"
                           prefWidth="280"
                           styleClass="admin-search-field"/>

                <!-- Filtre type -->
                <Label text="Type :"
                       style="-fx-font-size: 13px; -fx-text-fill: #666688;"/>
                <ComboBox fx:id="typeFilter"
                           onAction="#search"
                           prefWidth="140"
                           style="-fx-font-size: 13px;"/>

                <HBox HBox.hgrow="ALWAYS"/>

                <!-- Status -->
                <Label fx:id="statusLabel"
                       text="0 utilisateur(s)"
                       styleClass="stat-sublabel" style="-fx-font-size: 12px;"/>
            </HBox>

            <!-- Tableau -->
            <TableView fx:id="userTable"
                       VBox.vgrow="ALWAYS"
                       styleClass="admin-table-full">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="55"
                                 styleClass="admin-table-cell-center"/>
                    <TableColumn fx:id="colFirstName" text="Prénom" prefWidth="130"/>
                    <TableColumn fx:id="colLastName"  text="Nom"    prefWidth="130"/>
                    <TableColumn fx:id="colEmail"     text="Email"  prefWidth="220"/>
                    <TableColumn fx:id="colType"      text="Type"   prefWidth="110"
                                 styleClass="admin-table-cell-center"/>
                    <TableColumn fx:id="colActive"    text="Actif"  prefWidth="80"
                                 styleClass="admin-table-cell-center"/>
                    <TableColumn fx:id="colActions"   text="Actions" prefWidth="160"
                                 styleClass="admin-table-cell-center"/>
                </columns>
                <placeholder>
                    <Label text="Aucun utilisateur trouvé."
                           styleClass="stat-sublabel" style="-fx-font-size: 14px;"/>
                </placeholder>
            </TableView>

            <!-- Footer barre d'actions -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  styleClass="admin-action-bar">

                <Button text="Modifier"
                        onAction="#editSelectedUser"
                        styleClass="admin-btn-action-blue"/>

                <Button text="Activer / Désactiver"
                        onAction="#toggleActiveUser"
                        styleClass="admin-btn-action-orange"/>

                <Button text="Supprimer"
                        onAction="#deleteUser"
                        styleClass="auth-primary-button" style="-fx-font-size: 12px; -fx-padding: 7 16; -fx-background-radius: 5;"/>

                <HBox HBox.hgrow="ALWAYS"/>

                <Button text="Actualiser"
                        onAction="#refreshList"
                        styleClass="admin-btn-action-refresh"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
