<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.paint.Color?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.eduplay.controllers.ChildLibraryController" style="-fx-background-color: #F8FAFC;">
    
    <!-- Organic Background Shapes -->
    <Circle radius="250" fill="#f9a8d4" opacity="0.3" layoutX="0" layoutY="0">
        <effect><GaussianBlur radius="80"/></effect>
    </Circle>
    <Circle radius="300" fill="#93c5fd" opacity="0.3" layoutX="1000" layoutY="600">
        <effect><GaussianBlur radius="80"/></effect>
    </Circle>

    <ScrollPane fx:id="scrollPane" fitToWidth="true" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox alignment="TOP_CENTER" spacing="0">
            
            <!-- Header Public (Bypass Sidebar) -->
            <VBox alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.8); -fx-border-color: #F1F5F9; -fx-border-width: 0 0 1 0;">
                <HBox alignment="CENTER_LEFT" spacing="20" maxWidth="1200" style="-fx-padding: 16 30;">
                    <!-- Logo Info -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane style="-fx-background-color: #2B7CEE; -fx-background-radius: 12; -fx-min-width: 40; -fx-min-height: 40; -fx-effect: dropshadow(three-pass-box, rgba(43,124,238,0.3), 10, 0, 0, 4);">
                            <Label text="📚" style="-fx-font-size: 20px; -fx-text-fill: white;"/>
                        </StackPane>
                        <Label text="EduPlay" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111418;"/>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <HBox alignment="CENTER" spacing="16">
                        <Label text="Accueil" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2B7CEE; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 20; -fx-cursor: hand;"/>
                    </HBox>
                </HBox>
            </VBox>

            <!-- Main Content -->
            <VBox alignment="TOP_CENTER" spacing="40" maxWidth="1200" style="-fx-padding: 40 30;">
                
                <!-- Hero Section -->
                <VBox alignment="CENTER" spacing="16" maxWidth="800">
                    <Label text="Explorez Votre Bibliothèque" style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #111418;"/>
                    <Label text="Découvrez des histoires incroyables, résolvez des énigmes mathématiques et explorez les merveilles de l'univers !" style="-fx-font-size: 18px; -fx-text-fill: #64748B; -fx-wrap-text: true; -fx-text-alignment: center;" maxWidth="600"/>
                    
                    <!-- Barre de recherche -->
                    <VBox style="-fx-padding: 20 0 0 0;" maxWidth="600" alignment="CENTER">
                        <TextField fx:id="searchField" promptText="🔍 Que voulez-vous apprendre aujourd'hui ?" style="-fx-background-color: white; -fx-font-size: 16px; -fx-padding: 16 24; -fx-background-radius: 16; -fx-border-color: #E2E8F0; -fx-border-radius: 16; -fx-border-width: 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 20, 0, 0, 4); -fx-pref-width: 600;"/>
                    </VBox>
                </VBox>
                
                <!-- Grille -->
                <FlowPane fx:id="libraryContainer" hgap="32" vgap="32" alignment="TOP_CENTER" maxWidth="1200" />
                
            </VBox>

            <!-- Footer -->
            <VBox alignment="CENTER" style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0; -fx-padding: 60 30;">
                <HBox alignment="CENTER_LEFT" maxWidth="1200" spacing="100">
                    <VBox spacing="16" maxWidth="300">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <StackPane style="-fx-background-color: #2B7CEE; -fx-background-radius: 16; -fx-min-width: 32; -fx-min-height: 32;">
                                <Label text="🚀" style="-fx-text-fill: white;"/>
                            </StackPane>
                            <Label text="EduPlay" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label text="Faire de l'apprentissage une aventure pour chaque enfant, partout." style="-fx-text-fill: #617989; -fx-font-size: 14px; -fx-wrap-text: true;"/>
                    </VBox>
                    <VBox spacing="10">
                        <Label text="Découvrir" style="-fx-font-weight: bold;"/>
                        <Label text="Bibliothèque de Lecture" style="-fx-text-fill: #617989;"/>
                        <Label text="Kits STEM" style="-fx-text-fill: #617989;"/>
                    </VBox>
                    <VBox spacing="10">
                        <Label text="Support" style="-fx-font-weight: bold;"/>
                        <Label text="Centre d'Aide" style="-fx-text-fill: #617989;"/>
                        <Label text="Contactez-nous" style="-fx-text-fill: #617989;"/>
                    </VBox>
                </HBox>
                <VBox alignment="CENTER_LEFT" maxWidth="1200" style="-fx-padding: 20 0 0 0;">
                    <Label text="© 2024 EduPlay Médias Éducatifs. Tous droits réservés." style="-fx-text-fill: #9CA3AF; -fx-font-size: 12px;"/>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>
</AnchorPane>
