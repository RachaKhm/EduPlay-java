<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.BrickBreakerController"
            prefWidth="700" prefHeight="550">

    <top>
        <HBox alignment="CENTER" spacing="30" style="-fx-padding: 15; -fx-background-color: #0F0F23;">
            <Label text="🏓 CASSE-BRIQUES" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
            <Label fx:id="scoreLabel" text="Score: 0" style="-fx-font-size: 16px; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="livesLabel" text="❤️ Vies: 3" style="-fx-font-size: 16px; -fx-text-fill: #FF6B6B; -fx-font-weight: bold;"/>
            <Label fx:id="levelLabel" text="Niveau: 1" style="-fx-font-size: 16px; -fx-text-fill: #F39C12; -fx-font-weight: bold;"/>
            <Button text="❌ Quitter" onAction="#closeGame" style="-fx-background-color: #E94560; -fx-text-fill: white; -fx-padding: 5 20; -fx-background-radius: 20;"/>
        </HBox>
    </top>

    <center>
        <Pane fx:id="gamePane" style="-fx-background-color: #1A1A2E;"/>
    </center>

</BorderPane>