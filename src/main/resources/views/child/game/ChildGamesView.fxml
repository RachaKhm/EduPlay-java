<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.ChildGamesController"
            prefWidth="900"
            style="-fx-background-color: #F8F9FA;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1A1A2E; -fx-padding: 18 24;">
            <VBox spacing="3">
                <Label text="Mes jeux éducatifs"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Apprends en t'amusant — EduPlay"
                       style="-fx-font-size: 11px; -fx-text-fill: #555577;"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 28 24 28;">

            <!-- Barre de recherche -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="🔍" style="-fx-font-size: 16px;"/>
                <TextField fx:id="searchField" promptText="Rechercher un jeu..."
                           style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                  -fx-border-width: 1; -fx-background-radius: 20;
                                  -fx-border-radius: 20; -fx-padding: 10 16; -fx-font-size: 13px;
                                  -fx-pref-width: 300;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusLabel" text="0 jeu(x)"
                       style="-fx-text-fill: #777799; -fx-font-size: 12px;"/>
            </HBox>

            <!-- Grille des jeux -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox spacing="20">
                    <TilePane fx:id="gamesGrid" prefColumns="3" hgap="20" vgap="20"
                              alignment="CENTER" style="-fx-padding: 10;"/>
                </VBox>
            </ScrollPane>

        </VBox>
    </center>

</BorderPane>