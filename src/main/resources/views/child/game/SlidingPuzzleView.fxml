<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.SlidingPuzzleController"
            style="-fx-background-color: linear-gradient(to bottom, #1A1A2E, #16213E);">

    <top>
        <VBox spacing="10">
            <HBox alignment="CENTER" spacing="20" style="-fx-padding: 15; -fx-background-color: #0F0F23;">
                <Label text="🧩 T A Q U I N" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
                <Label fx:id="scoreLabel" text="🎯 Score: 0" style="-fx-font-size: 14px; -fx-text-fill: #2E9E6E; -fx-font-weight: bold;"/>
                <Label fx:id="movesLabel" text="🔄 Mouvements: 0" style="-fx-font-size: 14px; -fx-text-fill: #F39C12; -fx-font-weight: bold;"/>
                <Label fx:id="timeLabel" text="⏱️ 00:00" style="-fx-font-size: 14px; -fx-text-fill: #3498DB; -fx-font-weight: bold;"/>
                <Button text="🔄 Nouveau" onAction="#resetGame" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 20; -fx-cursor: hand;"/>
                <Button text="❌ Quitter" onAction="#closeGame" style="-fx-background-color: #E94560; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 20; -fx-cursor: hand;"/>
            </HBox>
            <Label text="📌 Cliquez sur une case adjacente à la case vide pour la déplacer"
                   style="-fx-font-size: 12px; -fx-text-fill: #AAAAAA; -fx-alignment: center;"/>
        </VBox>
    </top>

    <center>
        <GridPane fx:id="gridPane" alignment="CENTER" hgap="8" vgap="8" style="-fx-padding: 20;">
        </GridPane>
    </center>

</BorderPane>