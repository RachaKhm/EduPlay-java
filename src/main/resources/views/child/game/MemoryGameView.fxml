<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.MemoryGameController"
            style="-fx-background-color: linear-gradient(to bottom, #1A1A2E, #16213E);">

    <top>
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 20;">
            <Label text="🎮 Jeu Memory" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="scoreLabel" text="Score: 0" style="-fx-font-size: 18px; -fx-text-fill: #E94560; -fx-font-weight: bold;"/>
            <Label fx:id="turnsLabel" text="Tours: 0" style="-fx-font-size: 18px; -fx-text-fill: #F39C12;"/>
            <Label fx:id="pairsLabel" text="Paires: 0/8" style="-fx-font-size: 18px; -fx-text-fill: #2E9E6E;"/>
            <Button text="Nouveau" onAction="#resetGame" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 20;"/>
            <Button text="Quitter" onAction="#closeGame" style="-fx-background-color: #E94560; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 20;"/>
        </HBox>
    </top>

    <center>
        <GridPane fx:id="gridPane" alignment="CENTER" hgap="10" vgap="10" style="-fx-padding: 20;">
        </GridPane>
    </center>

</BorderPane>