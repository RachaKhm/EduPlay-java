<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.ChildDashboardController"
      spacing="0" 
      stylesheets="@../../styles/child.css"
      styleClass="child-container"
      style="-fx-padding: 24;">
    <HBox style="-fx-padding: 0 0 32 0;">
        <VBox spacing="8">
            <Label text="Mon espace"
                   styleClass="child-header-title"/>
            <Label fx:id="subtitleLabel" text="Bienvenue dans ton univers magique !"
                   styleClass="child-section-label"/>
        </VBox>
    </HBox>
    <HBox spacing="24">
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              styleClass="child-stat-card-courses">
            <Label text="Mes cours" styleClass="child-stat-label-courses"/>
            <Label fx:id="totalCoursesLabel" text="—"
                   styleClass="child-stat-value-courses"/>
        </VBox>
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              styleClass="child-stat-card-games">
            <Label text="Jeux disponibles" styleClass="child-stat-label-games"/>
            <Label fx:id="totalGamesLabel" text="—"
                   styleClass="child-stat-value-games"/>
        </VBox>
    </HBox>
</VBox>
