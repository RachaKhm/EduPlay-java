<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.UserFormController"
            prefWidth="560"
            stylesheets="@../../styles/child.css"
            styleClass="child-container">

    <!-- ===== HEADER ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              styleClass="child-header">
            <Label fx:id="formTitle"
                   text="Nouvel utilisateur"
                   styleClass="child-header-title"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="✕"
                    onAction="#closeForm"
                    styleClass="child-close-btn"/>
        </HBox>
    </top>

    <!-- ===== FORMULAIRE ===== -->
    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="child-scroll-pane">
            <VBox spacing="0"
                  styleClass="child-form-content">

                <!-- Section : Informations générales -->
                <Label text="Informations générales"
                       styleClass="child-section-label"/>

                <HBox spacing="16">
                    <!-- Prénom -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Prénom *"
                               styleClass="child-label"/>
                        <TextField fx:id="firstNameField"
                                   promptText="ex: Mohamed"
                                   styleClass="child-input"/>
                        <Label fx:id="firstNameError" text="" styleClass="child-error-label" wrapText="true"/>
                    </VBox>
                    <!-- Nom -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Nom *"
                               styleClass="child-label"/>
                        <TextField fx:id="lastNameField"
                                   promptText="ex: Ben Ali"
                                   styleClass="child-input"/>
                        <Label fx:id="lastNameError" text="" styleClass="child-error-label" wrapText="true"/>
                    </VBox>
                </HBox>

                <VBox spacing="4" styleClass="child-field-container">
                    <Label text="Email"
                           styleClass="child-label"/>
                    <TextField fx:id="emailField"
                               promptText="ex: user@eduplay.com"
                               styleClass="child-input"/>
                    <Label fx:id="emailError" text="" styleClass="child-error-label" wrapText="true"/>
                </VBox>

                <HBox spacing="16" styleClass="child-field-container">
                    <!-- Téléphone -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Téléphone"
                               styleClass="child-label"/>
                        <TextField fx:id="telephoneField"
                                   promptText="ex: +216 XX XXX XXX"
                                   styleClass="child-input"/>
                        <Label fx:id="telephoneError" text="" styleClass="child-error-label" wrapText="true"/>
                    </VBox>
                    <!-- Type -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Type *"
                               styleClass="child-label"/>
                        <ComboBox fx:id="typeCombo"
                                  maxWidth="Infinity"
                                  style="-fx-font-size: 13px;"/>
                        <Label fx:id="typeError" text="" styleClass="child-error-label" wrapText="true"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" styleClass="child-field-container">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Adresse"
                               styleClass="child-label"/>
                        <TextField fx:id="adresseField"
                                   promptText="ex: 12 rue de la République, Tunis"
                                   styleClass="child-input"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Date de naissance"
                               styleClass="child-label"/>
                        <DatePicker fx:id="birthDateField"
                                   promptText="JJ/MM/AAAA"
                                   styleClass="child-input"
                                   style="-fx-padding: 4 6;"
                                   maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <!-- Séparateur -->
                <Separator style="-fx-padding: 14 0 0 0;"/>

                <!-- Section : Sécurité -->
                <Label text="Sécurité"
                       styleClass="child-section-label" style="-fx-padding: 14 0 8 0;"/>

                <VBox spacing="4">
                    <Label text="Mot de passe *"
                           styleClass="child-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Minimum 6 caractères"
                                   styleClass="child-input"/>
                    <Label fx:id="passwordError" text="" styleClass="child-error-label" wrapText="true"/>
                </VBox>
                <VBox spacing="4" styleClass="child-field-container">
                    <Label text="Confirmer le mot de passe *"
                           styleClass="child-label"/>
                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Confirmer le mot de passe"
                                   styleClass="child-input"/>
                    <Label fx:id="confirmPasswordError" text="" styleClass="child-error-label" wrapText="true"/>
                </VBox>

                <CheckBox fx:id="activeCheck"
                          text="Compte actif"
                          selected="true"
                          style="-fx-font-size: 13px; -fx-text-fill: #444466;
                                 -fx-padding: 14 0 0 0;"/>

                <!-- Séparateur -->
                <Separator style="-fx-padding: 14 0 0 0;"/>

                <!-- ===== CHAMPS CONDITIONNELS ===== -->

                <!-- Spécialité (enseignant uniquement) -->
                <HBox fx:id="specialiteBox" spacing="0" managed="false" visible="false"
                      style="-fx-padding: 14 0 0 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Spécialité *  —  Enseignant"
                               styleClass="child-section-label" style="-fx-padding: 0 0 4 0;"/>
                        <TextField fx:id="specialiteField"
                                   promptText="ex: Mathématiques, Informatique..."
                                   styleClass="child-input, child-input-special"/>
                        <Label fx:id="specialiteError" text="" styleClass="child-error-label" wrapText="true"/>
                    </VBox>
                </HBox>

                <!-- Niveau + Username (enfant uniquement) -->
                <HBox fx:id="niveauBox" spacing="16" managed="false" visible="false"
                      style="-fx-padding: 14 0 0 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Niveau  —  Enfant"
                               styleClass="child-section-label" style="-fx-padding: 0 0 4 0;"/>
                        <ComboBox fx:id="niveauCombo" maxWidth="Infinity"
                                  style="-fx-font-size: 13px;"/>
                        <Label fx:id="niveauError" text="" styleClass="child-error-label" wrapText="true"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Nom d'utilisateur *"
                               styleClass="child-label"/>
                        <TextField fx:id="usernameField"
                                   promptText="ex: zied123"
                                   styleClass="child-input"/>
                        <Label fx:id="usernameError" text="" styleClass="child-error-label" wrapText="true"/>
                    </VBox>
                </HBox>

                <!-- Message succès -->
                <Label fx:id="successLabel" text="" wrapText="true"
                       styleClass="child-success-label"/>

                <!-- Boutons -->
                <HBox spacing="12" alignment="CENTER_RIGHT"
                      styleClass="child-button-container">
                    <Button text="Annuler"
                            onAction="#closeForm"
                            styleClass="child-btn-cancel"/>
                    <Button text="Enregistrer"
                            onAction="#saveUser"
                            styleClass="child-btn-save"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
