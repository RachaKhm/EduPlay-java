<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.paint.Color?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.eduplay.controllers.ChildResourceController" style="-fx-background-color: #F8FAFC;">
    
    <!-- Organic Background Shapes (Restricted within StackPane boundaries) -->
    <Pane style="-fx-background-color: transparent;" StackPane.alignment="CENTER">
        <Circle radius="150" fill="#93c5fd" opacity="0.3" centerX="150" centerY="150">
            <effect><GaussianBlur radius="80"/></effect>
        </Circle>
        <Circle radius="200" fill="#c4b5fd" opacity="0.3" centerX="800" centerY="500">
            <effect><GaussianBlur radius="80"/></effect>
        </Circle>
    </Pane>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
        <VBox alignment="TOP_CENTER" spacing="0">
            
            <!-- Main Content -->
            <VBox alignment="TOP_CENTER" spacing="32" maxWidth="1200" style="-fx-padding: 30 30 60 30;">
                
                <!-- Navbar / Header du Dashboard (similaire au child dashboard) -->
                <HBox alignment="CENTER_LEFT" maxWidth="1200" style="-fx-padding: 0 0 10 0;">
                    <VBox spacing="4">
                        <Label text="Bibliothèque" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Mes bibliothèques" style="-fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 13px;" onMouseClicked="#goBackToLibraries"/>
                            <Label text="&gt;" style="-fx-text-fill: #9CA3AF; -fx-font-size: 13px;"/>
                            <Label fx:id="lblLibraryNameNav" text="..." style="-fx-text-fill: #2563EB; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Library Info Hero -->
                <HBox spacing="32" style="-fx-background-color: linear-gradient(to right, #EFF6FF, #ffffff); -fx-border-color: #DBEAFE; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 32; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 20, 0, 0, 8);" maxWidth="1200">
                    <VBox fx:id="libraryImageContainer" alignment="CENTER" style="-fx-background-color: #DBEAFE; -fx-background-radius: 16; -fx-min-width: 200; -fx-min-height: 260; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);"/>
                    
                    <VBox spacing="16" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblLibraryName" text="Nom Bibliothèque" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        <HBox spacing="12">
                            <Label fx:id="lblTheme" text="💡 Theme" style="-fx-background-color: #DBEAFE; -fx-text-fill: #1D4ED8; -fx-padding: 6 16; -fx-background-radius: 20; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblAge" text="👶 Âge" style="-fx-background-color: #D1FAE5; -fx-text-fill: #047857; -fx-padding: 6 16; -fx-background-radius: 20; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <Label fx:id="lblLevel" text="🎓 Niveau" style="-fx-background-color: #F3E8FF; -fx-text-fill: #7E22CE; -fx-padding: 6 16; -fx-background-radius: 20; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        </HBox>
                        <Label fx:id="lblLibraryDesc" text="Description..." style="-fx-font-size: 15px; -fx-text-fill: #4B5563; -fx-wrap-text: true;" VBox.vgrow="ALWAYS"/>
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="📚" style="-fx-font-size: 16px;"/>
                            <Label fx:id="lblResourceCount" text="0 livres" style="-fx-font-weight: bold; -fx-text-fill: #374151; -fx-font-size: 14px;"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- Voice Search Mock & Request Book -->
                <HBox spacing="24" maxWidth="1200">
                    <HBox HBox.hgrow="ALWAYS" spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #F5F3FF, #EEF2FF); -fx-border-color: #E0E7FF; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 20;">
                        <StackPane style="-fx-background-color: #E0E7FF; -fx-background-radius: 12; -fx-min-width: 48; -fx-min-height: 48;">
                            <Label text="🎤" style="-fx-font-size: 24px;"/>
                        </StackPane>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Recherche Vocale" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #5B21B6;"/>
                            <Label text="Dis le nom d'un livre pour le trouver !" style="-fx-text-fill: #8B5CF6; -fx-font-size: 12px;"/>
                        </VBox>
                        <Label text="🎤 Parler" style="-fx-background-color: #7C3AED; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;"/>
                    </HBox>
                    <HBox HBox.hgrow="ALWAYS" spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #FFF7ED, #FFEDD5); -fx-border-color: #FFEDD5; -fx-border-radius: 16; -fx-background-radius: 16; -fx-padding: 20;">
                        <StackPane style="-fx-background-color: #FFEDD5; -fx-background-radius: 12; -fx-min-width: 48; -fx-min-height: 48;">
                            <Label text="🔔" style="-fx-font-size: 24px;"/>
                        </StackPane>
                        <VBox spacing="4">
                            <Label text="Notifications" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #9A3412;"/>
                            <Label text="Tes livres demandés disponibles !" style="-fx-text-fill: #EA580C; -fx-font-size: 12px;"/>
                        </VBox>
                    </HBox>
                </HBox>

                <!-- Resources Title -->
                <HBox alignment="CENTER_LEFT" spacing="16" maxWidth="1200" style="-fx-padding: 10 0 0 0;">
                    <Label text="Livres disponibles" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblResourceCountAlt" text="0 livres" style="-fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-font-size: 15px;"/>
                </HBox>

                <!-- Resource Grid -->
                <FlowPane fx:id="resourceContainer" hgap="32" vgap="32" alignment="TOP_LEFT" maxWidth="1200" />
                
            </VBox>

        </VBox>
    </ScrollPane>
</StackPane>
