<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.event.AddEventController"
            stylesheets="@/styles/add_event.css" styleClass="root-container">
    <content>
        <VBox alignment="TOP_CENTER" spacing="0">
            <padding>
                <Insets top="40" right="20" bottom="40" left="20"/>
            </padding>

            <VBox styleClass="form-card" spacing="25">
                <VBox spacing="5">
                    <Label text="📝 Ajouter un nouvel événement" styleClass="title-label"/>
                    <Label text="Remplissez les détails ci-dessous pour créer un événement inoubliable." styleClass="subtitle-label"/>
                    <Separator/>
                </VBox>

                <GridPane hgap="20" vgap="18">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" prefWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <!-- Titre -->
                    <Label text="Titre de l'événement" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="titleField" promptText="Ex: Grand Gala de Printemps" styleClass="text-input" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <!-- Description -->
                    <Label text="Description" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
                    <VBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="1">
                        <TextArea fx:id="descriptionArea" promptText="Décrivez l'événement en quelques mots..." prefHeight="120" wrapText="true" styleClass="text-input"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <ComboBox fx:id="targetPublicCombo" prefWidth="150" promptText="Public cible" styleClass="combo-box"/>
                            <ComboBox fx:id="descriptionStyleCombo" prefWidth="120" promptText="Style" styleClass="combo-box"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="generateDescBtn" text="✨ Générer par IA" styleClass="ai-button"/>
                        </HBox>
                    </VBox>

                    <!-- Dates Section -->
                    <Label text="Planification" styleClass="section-title" GridPane.rowIndex="2" GridPane.columnSpan="2"/>

                    <Label text="Début" styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="3" GridPane.columnIndex="1">
                        <DatePicker fx:id="startDatePicker" promptText="Date" prefWidth="180" styleClass="date-picker"/>
                        <TextField fx:id="startTimeField" promptText="HH:MM" prefWidth="90" styleClass="text-input"/>
                        <Label text="ex: 14:30" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    </HBox>

                    <Label text="Fin" styleClass="field-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="4" GridPane.columnIndex="1">
                        <DatePicker fx:id="endDatePicker" promptText="Date" prefWidth="180" styleClass="date-picker"/>
                        <TextField fx:id="endTimeField" promptText="HH:MM" prefWidth="90" styleClass="text-input"/>
                        <Label text="ex: 17:00" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    </HBox>

                    <!-- Logistique -->
                    <Label text="Logistique" styleClass="section-title" GridPane.rowIndex="5" GridPane.columnSpan="2"/>

                    <Label text="Lieu" styleClass="field-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                    <TextField fx:id="locationField" promptText="Où se déroule l'événement ?" styleClass="text-input" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                    <Label text="Capacité" styleClass="field-label" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="7" GridPane.columnIndex="1">
                        <TextField fx:id="maxCapacityField" promptText="Ex: 50" prefWidth="100" styleClass="text-input"/>
                        <Label text="participants maximum" style="-fx-text-fill: #64748b;"/>
                    </HBox>

                    <!-- Image -->
                    <Label text="Image de couverture" styleClass="field-label" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                    <HBox spacing="12" alignment="CENTER_LEFT" GridPane.rowIndex="8" GridPane.columnIndex="1">
                        <Button text="📁 Choisir un fichier" onAction="#chooseImage" styleClass="btn-choose"/>
                        <Label fx:id="imagePathLabel" text="Aucune image sélectionnée" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                    </HBox>
                </GridPane>

                <VBox alignment="CENTER" spacing="10">
                    <Label fx:id="messageLabel" text="" visible="false" managed="false" style="-fx-font-weight: bold;"/>
                    <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                        <Button fx:id="cancelBtn" text="Annuler" styleClass="btn-cancel"/>
                        <Button fx:id="submitBtn" text="🚀 Créer l'événement" styleClass="btn-submit"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>