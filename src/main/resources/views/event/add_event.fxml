<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css"
            fx:controller="dev.eduplay.controllers.event.AddEventController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #F8FAFC;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <VBox spacing="0" styleClass="premium-card">
                    <HBox alignment="CENTER_LEFT" styleClass="premium-header" style="-fx-padding: 20 30;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="➕ Créer un événement" styleClass="premium-title">
                                <font><Font name="System Bold" size="24"/></font>
                            </Label>
                            <Label text="Remplissez le formulaire ci-dessous" styleClass="premium-subtitle" style="-fx-padding: 5 0 0 0;"/>
                        </VBox>
                        <Button fx:id="cancelBtn" text="← Retour" styleClass="btn-icon"/>
                    </HBox>
                </VBox>

                <VBox spacing="20" styleClass="premium-card" style="-fx-background-color: white;">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25"/>
                    </padding>

                    <children>
                        <VBox spacing="5">
                            <Label text="Titre *" styleClass="field-label"/>
                            <TextField fx:id="titleField" promptText="Ex: Atelier Petits Mosaïstes" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Date début *" styleClass="field-label"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <DatePicker fx:id="startDatePicker" promptText="AAAA-MM-JJ" prefWidth="180" styleClass="date-picker"/>
                                <ComboBox fx:id="startHourCombo" prefWidth="80" promptText="HH" styleClass="date-picker"/>
                                <Label text=":" style="-fx-padding: 0;"/>
                                <ComboBox fx:id="startMinuteCombo" prefWidth="80" promptText="MM" styleClass="date-picker"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Date fin *" styleClass="field-label"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <DatePicker fx:id="endDatePicker" promptText="AAAA-MM-JJ" prefWidth="180" styleClass="date-picker"/>
                                <ComboBox fx:id="endHourCombo" prefWidth="80" promptText="HH" styleClass="date-picker"/>
                                <Label text=":" style="-fx-padding: 0;"/>
                                <ComboBox fx:id="endMinuteCombo" prefWidth="80" promptText="MM" styleClass="date-picker"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Lieu *" styleClass="field-label"/>
                            <TextField fx:id="locationField" promptText="Ex: Musée du Bardo, Tunis" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Description *" styleClass="field-label"/>
                            <TextArea fx:id="descriptionArea" promptText="Description détaillée de l'événement..." prefHeight="100" wrapText="true" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Image" styleClass="field-label"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button fx:id="browseImageBtn" text="📁 Choisir un fichier" styleClass="btn-secondary"/>
                                <Label fx:id="fileNameLabel" text="Aucun fichier sélectionné" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                            </HBox>
                        </VBox>

                        <Label fx:id="messageLabel" wrapText="true" style="-fx-font-size: 13px;"/>

                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                            <Button fx:id="submitBtn" text="✅ Créer l'événement" styleClass="btn-primary"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
