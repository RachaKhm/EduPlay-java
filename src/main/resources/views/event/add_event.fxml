<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/20.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.event.AddEventController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color: #f3f4f6;">

    <padding>
        <Insets top="25" right="35" bottom="25" left="35"/>
    </padding>

    <children>
        <Label text="📝 Ajouter un événement" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

        <GridPane hgap="15" vgap="15">
            <!-- Ligne 1: Titre -->
            <Label text="Titre *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <TextField fx:id="titleField" promptText="Ex: Atelier de peinture" GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.columnSpan="3" prefWidth="400"/>

            <!-- Ligne 2: Description -->
            <Label text="Description *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3" spacing="8">
                <TextArea fx:id="descriptionArea" promptText="Description de l'événement..." prefHeight="120" wrapText="true"/>

                <!-- NOUVEAU : Section de génération IA -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <ComboBox fx:id="targetPublicCombo" prefWidth="130" promptText="Public cible"/>
                    <ComboBox fx:id="descriptionStyleCombo" prefWidth="100" promptText="Style"/>
                    <Button fx:id="generateDescBtn" text="✨ Générer description avec IA"
                            style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Ligne 3: Date début -->
            <Label text="Date début *" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <DatePicker fx:id="startDatePicker" promptText="jj/mm/aaaa" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            <TextField fx:id="startTimeField" promptText="HH:MM" prefWidth="80" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
            <Label text="ex: 14:00" GridPane.rowIndex="2" GridPane.columnIndex="3" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>

            <!-- Ligne 4: Date fin -->
            <Label text="Date fin *" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <DatePicker fx:id="endDatePicker" promptText="jj/mm/aaaa" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            <TextField fx:id="endTimeField" promptText="HH:MM" prefWidth="80" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
            <Label text="ex: 16:00" GridPane.rowIndex="3" GridPane.columnIndex="3" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>

            <!-- Ligne 5: Lieu -->
            <Label text="Lieu *" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <TextField fx:id="locationField" promptText="Adresse ou nom du lieu" GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.columnSpan="3"/>

            <!-- Ligne 6: Capacité -->
            <Label text="Capacité max *" GridPane.rowIndex="5" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <TextField fx:id="maxCapacityField" promptText="Nombre de places" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <!-- Ligne 7: Coordonnées -->
            <Label text="Latitude" GridPane.rowIndex="6" GridPane.columnIndex="0" style="-fx-text-fill: #6b7280;"/>
            <TextField fx:id="latitudeField" promptText="Ex: 48.8566" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
            <Label text="Longitude" GridPane.rowIndex="6" GridPane.columnIndex="2" style="-fx-text-fill: #6b7280;"/>
            <TextField fx:id="longitudeField" promptText="Ex: 2.3522" GridPane.rowIndex="6" GridPane.columnIndex="3"/>

            <!-- Ligne 8: Image -->
            <Label text="Image" GridPane.rowIndex="7" GridPane.columnIndex="0" style="-fx-text-fill: #6b7280;"/>
            <HBox GridPane.rowIndex="7" GridPane.columnIndex="1" GridPane.columnSpan="3" spacing="10">
                <Button text="📁 Choisir une image" onAction="#chooseImage" style="-fx-cursor: hand;"/>
                <Label fx:id="imagePathLabel" text="Aucun fichier choisi" style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
            </HBox>
        </GridPane>

        <!-- Message de statut -->
        <Label fx:id="messageLabel" text="" visible="false" managed="false" style="-fx-font-size: 12px;"/>

        <!-- Boutons d'action -->
        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="cancelBtn" text="Annuler" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
            <Button fx:id="submitBtn" text="Ajouter l'événement" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 25; -fx-cursor: hand;"/>
        </HBox>
    </children>
</VBox>