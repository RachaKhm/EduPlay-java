<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.event.EventResourceController"
            style="-fx-background-color: #f3f4f6; -fx-background: #f3f4f6;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #f3f4f6;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <!-- En-tête -->
                <VBox spacing="0" style="-fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #6d28d9); -fx-background-radius: 16 16 0 0; -fx-padding: 20 25;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="eventTitleLabel" text="📚 Gestion des ressources" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;">
                                <font><Font name="System Bold" size="24"/></font>
                            </Label>
                            <Label fx:id="eventSubtitleLabel" text="Gérer les documents, vidéos et liens associés" style="-fx-text-fill: #ddd6fe; -fx-font-size: 13px; -fx-padding: 5 0 0 0;"/>
                        </VBox>
                        <Button fx:id="backBtn" text="← Retour à l'événement" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 12; -fx-cursor: hand;"/>
                    </HBox>

                    <!-- Barre d'outils -->
                    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 15 25; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 1 1; -fx-background-radius: 0 0 16 16;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Liste des ressources" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                            <Label fx:id="resourceCountLabel" text="0 ressource(s)" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                        </VBox>
                        <TextField fx:id="searchField" promptText="🔍 Rechercher par titre..." prefWidth="250" style="-fx-padding: 10 15; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;"/>
                        <ComboBox fx:id="typeFilterCombo" prefWidth="140" promptText="Tous les types" style="-fx-padding: 8; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;"/>
                        <Button fx:id="addResourceBtn" text="➕ Nouvelle ressource" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(139,92,246,0.3), 5, 0, 0, 2);"/>
                        <Button fx:id="refreshBtn" text="🔄 Rafraîchir" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Tableau -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="resourceTable" VBox.vgrow="ALWAYS" prefHeight="400" style="-fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                            <placeholder>
                                <Label text="📭 Aucune ressource trouvée" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                            </placeholder>
                            <columns>
                                <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
                                <TableColumn fx:id="colTitle" text="Titre" prefWidth="380"/>
                                <TableColumn fx:id="colCreatedAt" text="Date de création" prefWidth="160"/>
                                <TableColumn fx:id="colActions" text="Actions" prefWidth="220"/>
                            </columns>
                        </TableView>

                        <!-- Pagination -->
                        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 15; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
                            <Button fx:id="prevBtn" text="◀ Précédent" style="-fx-background-color: #f3f4f6; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                            <Label fx:id="pageInfo" text="Page 1 sur 1" style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                            <Button fx:id="nextBtn" text="Suivant ▶" style="-fx-background-color: #f3f4f6; -fx-padding: 8 16; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>