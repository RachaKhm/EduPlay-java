<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.event.EditEventController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #F8FAFC;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <!-- Header -->
                <VBox spacing="0" style="-fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #f59e0b, #d97706); -fx-background-radius: 16 16 0 0; -fx-padding: 20 25;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="✏️ Modifier l'événement" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;">
                                <font><Font name="System Bold" size="24"/></font>
                            </Label>
                            <Label text="Modifiez les informations ci-dessous" style="-fx-text-fill: #fde68a; -fx-font-size: 13px; -fx-padding: 5 0 0 0;"/>
                        </VBox>
                        <Button fx:id="cancelBtn" text="← Retour" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 12; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Formulaire -->
                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25"/>
                    </padding>

                    <children>
                        <!-- Titre -->
                        <VBox spacing="5">
                            <Label text="Titre *" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <TextField fx:id="titleField" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-background-color: white; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Date début -->
                        <VBox spacing="5">
                            <Label text="Date début *" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <DatePicker fx:id="startDatePicker" promptText="AAAA-MM-JJ" prefWidth="180" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <ComboBox fx:id="startHourCombo" prefWidth="80" promptText="HH" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <Label text=":" style="-fx-padding: 0;"/>
                                <ComboBox fx:id="startMinuteCombo" prefWidth="80" promptText="MM" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                            </HBox>
                        </VBox>

                        <!-- Date fin -->
                        <VBox spacing="5">
                            <Label text="Date fin *" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <DatePicker fx:id="endDatePicker" promptText="AAAA-MM-JJ" prefWidth="180" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <ComboBox fx:id="endHourCombo" prefWidth="80" promptText="HH" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <Label text=":" style="-fx-padding: 0;"/>
                                <ComboBox fx:id="endMinuteCombo" prefWidth="80" promptText="MM" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                            </HBox>
                        </VBox>

                        <!-- Lieu -->
                        <VBox spacing="5">
                            <Label text="Lieu *" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <TextField fx:id="locationField" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-background-color: white; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- ✅ CAPACITÉ MAXIMALE AJOUTÉE ICI -->
                        <VBox spacing="5">
                            <Label text="Capacité maximale *" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <TextField fx:id="capacityField" promptText="Nombre de places" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-background-color: white; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Description -->
                        <VBox spacing="5">
                            <Label text="Description *" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <TextArea fx:id="descriptionArea" prefHeight="100" wrapText="true" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-background-color: white; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Image -->
                        <VBox spacing="5">
                            <Label text="Image" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button fx:id="browseImageBtn" text="📁 Choisir un fichier" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                                <Label fx:id="fileNameLabel" text="Aucun fichier sélectionné" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                            </HBox>
                        </VBox>

                        <!-- Aperçu image -->
                        <StackPane fx:id="imagePreviewPane" prefHeight="150" prefWidth="250" style="-fx-background-color: #f8fafc; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-border-style: dashed;" visible="false" managed="false">
                            <Label text="🖼️ Aperçu de l'image" style="-fx-text-fill: #94a3b8;"/>
                        </StackPane>

                        <!-- Message -->
                        <Label fx:id="messageLabel" wrapText="true" style="-fx-font-size: 13px;"/>

                        <!-- Boutons -->
                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                            <Button fx:id="submitBtn" text="✅ Mettre à jour" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 12 30; -fx-background-radius: 25; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>