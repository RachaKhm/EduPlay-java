<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css"
            fx:controller="dev.eduplay.controllers.event.AddResourceController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #F8FAFC;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <VBox spacing="0" styleClass="premium-card">
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #6d28d9); -fx-background-radius: 16 16 0 0; -fx-padding: 20 25;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="📎 Ajouter une ressource" styleClass="premium-title">
                                <font><Font name="System Bold" size="24"/></font>
                            </Label>
                            <Label fx:id="eventTitleLabel" text="Pour l'événement" style="-fx-text-fill: #ddd6fe; -fx-font-size: 13px; -fx-padding: 5 0 0 0;"/>
                        </VBox>
                        <Button fx:id="cancelBtn" text="← Retour" styleClass="btn-icon"/>
                    </HBox>
                </VBox>

                <VBox spacing="20" styleClass="premium-card" style="-fx-background-color: white;">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25"/>
                    </padding>

                    <children>
                        <VBox spacing="5">
                            <Label text="Type *" styleClass="field-label"/>
                            <ComboBox fx:id="typeCombo" promptText="Sélectionnez un type" prefWidth="300" style="-fx-padding: 10; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Titre *" styleClass="field-label"/>
                            <TextField fx:id="titleField" promptText="Ex: Guide de l'événement" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="5">
                            <Label text="Contexte / Description" styleClass="field-label"/>
                            <TextArea fx:id="contextArea" promptText="Description détaillée de la ressource..." prefHeight="100" wrapText="true" styleClass="text-field"/>
                        </VBox>

                        <VBox fx:id="filePathBox" spacing="5" visible="false" managed="false">
                            <Label text="Chemin du fichier" styleClass="field-label"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="filePathField" promptText="Ex: /uploads/documents/guide.pdf" HBox.hgrow="ALWAYS" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <Button fx:id="browseFileBtn" text="📁 Parcourir" styleClass="btn-secondary"/>
                            </HBox>
                        </VBox>

                        <VBox fx:id="urlBox" spacing="5" visible="false" managed="false">
                            <Label text="URL" styleClass="field-label"/>
                            <TextField fx:id="urlField" promptText="Ex: https://example.com/document" styleClass="text-field"/>
                        </VBox>

                        <Label fx:id="messageLabel" wrapText="true" style="-fx-font-size: 13px;"/>

                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                            <Button fx:id="submitBtn" text="✅ Enregistrer" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 12 30; -fx-background-radius: 25; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
