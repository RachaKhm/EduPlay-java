<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Rectangle?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.event.EventDetailController"
            style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;"
            fitToWidth="true" fitToHeight="false" hbarPolicy="NEVER">

    <content>
        <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color: #f1f5f9;">
            <children>

                <!-- HEADER NAVIGATION -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 40 10 40;">
                    <Button fx:id="backBtn" text="← Retour à la liste"
                            style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 0;"/>
                </HBox>

                <!-- MAIN CARD CONTAINER -->
                <StackPane maxWidth="1000" alignment="TOP_CENTER" style="-fx-padding: 0 40 40 40;">
                    <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 20;
                           -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);">

                        <!-- HERO SECTION (IMAGE) -->
                        <StackPane prefHeight="320">
                            <ImageView fx:id="eventImageView" fitHeight="320" fitWidth="1000"
                                       preserveRatio="false" style="-fx-background-color: #e2e8f0;"/>

                            <!-- Overlay semi-transparent pour que le texte soit lisible -->
                            <Rectangle width="1000" height="320"
                                       style="-fx-fill: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,0.6));"/>

                            <!-- Titre et lieu superposés -->
                            <VBox alignment="BOTTOM_LEFT" spacing="8" style="-fx-padding: 0 30 30 30;">
                                <Label fx:id="titleValue" text="Chargement..." wrapText="true"
                                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                <Label fx:id="locationValue" text=""
                                       style="-fx-font-size: 16px; -fx-text-fill: #e2e8f0; -fx-font-weight: 500;"/>
                            </VBox>
                        </StackPane>

                        <!-- CONTENT AREA -->
                        <VBox spacing="25" style="-fx-padding: 35;">

                            <!-- INFO GRID -->
                            <GridPane hgap="40" vgap="25">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>

                                <children>
                                    <!-- Date & Time -->
                                    <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                        <Label text="📅 DATE ET HEURE"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b; -fx-letter-spacing: 1px;"/>
                                        <HBox spacing="20" alignment="CENTER_LEFT">
                                            <VBox>
                                                <Label text="Début" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                                                <Label fx:id="startDateValue" text="--/--/---- --:--"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                            </VBox>
                                            <VBox>
                                                <Label text="Fin" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                                                <Label fx:id="endDateValue" text="--/--/---- --:--"
                                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                                            </VBox>
                                        </HBox>
                                    </VBox>

                                    <!-- Participation -->
                                    <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                        <Label text="🎟️ PARTICIPATION"
                                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b; -fx-letter-spacing: 1px;"/>
                                        <VBox>
                                            <Label fx:id="registrationsCountValue" text="0 / 0 inscrits"
                                                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                                            <Label fx:id="capacityValue" text="Capacité: 0 places"
                                                   style="-fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                                        </VBox>
                                    </VBox>
                                </children>
                            </GridPane>

                            <Separator/>

                            <!-- DESCRIPTION -->
                            <VBox spacing="12">
                                <Label text="📝 À PROPOS DE CET ÉVÉNEMENT"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748b; -fx-letter-spacing: 1px;"/>
                                <Label fx:id="descriptionValue" text="Aucune description disponible."
                                       wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #475569;"/>
                            </VBox>

                            <!-- Création -->
                            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5 0 0 0;">
                                <Label text="🕒 Créé le:" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                                <Label fx:id="createdAtValue" text="--/--/----"
                                       style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                            </HBox>

                            <!-- ACTION BUTTONS -->
                            <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                                <Button fx:id="editBtn" text="✏️ Modifier"
                                        style="-fx-background-color: #eff6ff; -fx-text-fill: #3b82f6; -fx-padding: 12 30;
                                               -fx-background-radius: 12; -fx-cursor: hand; -fx-font-weight: bold;
                                               -fx-border-color: #3b82f6; -fx-border-radius: 12; -fx-border-width: 1;"/>

                                <Button fx:id="deleteBtn" text="🗑️ Supprimer"
                                        style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444; -fx-padding: 12 30;
                                               -fx-background-radius: 12; -fx-cursor: hand; -fx-font-weight: bold;
                                               -fx-border-color: #ef4444; -fx-border-radius: 12; -fx-border-width: 1;"/>

                                <Region HBox.hgrow="ALWAYS"/>

                                <Button fx:id="resourcesBtn" text="📚 Voir les ressources"
                                        style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 12 30;
                                               -fx-background-radius: 12; -fx-cursor: hand; -fx-font-weight: bold;
                                               -fx-effect: dropshadow(gaussian, rgba(139, 92, 246, 0.3), 10, 0, 0, 4);"/>
                            </HBox>

                        </VBox>
                    </VBox>
                </StackPane>
            </children>
        </VBox>
    </content>
</ScrollPane>