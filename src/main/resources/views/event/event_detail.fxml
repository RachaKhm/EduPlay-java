<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.event.EventDetailController"
            style="-fx-background-color: #f8f9fa; -fx-background: #f8f9fa;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #f8f9fa;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <!-- Retour -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button fx:id="backBtn" text="← Retour à la liste"
                            style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-padding: 10 20; -fx-background-radius: 25; -fx-cursor: hand; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Carte principale -->
                <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">

                    <!-- Image -->
                    <ImageView fx:id="eventImageView" fitHeight="280" fitWidth="Infinity" preserveRatio="false" style="-fx-background-color: #e2e8f0;"/>
                    <Label fx:id="noImageLabel" text="🖼️ Aucune image disponible" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px; -fx-padding: 20; -fx-alignment: center;" visible="false" managed="false"/>

                    <!-- Contenu -->
                    <VBox spacing="16" style="-fx-padding: 24;">

                        <!-- Titre -->
                        <Label fx:id="titleValue" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" wrapText="true"/>

                        <!-- Infos (date, lieu) -->
                        <HBox spacing="16">
                            <Label fx:id="startDateValue" style="-fx-font-size: 14px; -fx-text-fill: #8b5cf6; -fx-font-weight: bold;"/>
                            <Label fx:id="endDateValue" style="-fx-font-size: 14px; -fx-text-fill: #8b5cf6; -fx-font-weight: bold;"/>
                            <Label fx:id="locationValue" style="-fx-font-size: 14px; -fx-text-fill: #8b5cf6; -fx-font-weight: bold;"/>
                        </HBox>

                        <!-- Capacité -->
                        <HBox spacing="16">
                            <Label fx:id="capacityValue" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                            <Label fx:id="registrationsCountValue" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                        </HBox>

                        <Separator/>

                        <!-- Description -->
                        <Label text="📝 Description" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label fx:id="descriptionValue" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>

                        <Separator/>

                        <!-- Créé le -->
                        <Label text="📅 Créé le" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                        <Label fx:id="createdAtValue" style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>

                        <!-- Localisation -->
                        <VBox fx:id="locationBox" spacing="5" visible="false" managed="false">
                            <Label text="🗺️ Localisation" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                            <HBox spacing="10">
                                <Label text="Latitude:" style="-fx-text-fill: #64748b;"/>
                                <Label fx:id="latitudeValue" style="-fx-text-fill: #1e293b;"/>
                                <Label text="Longitude:" style="-fx-text-fill: #64748b;"/>
                                <Label fx:id="longitudeValue" style="-fx-text-fill: #1e293b;"/>
                            </HBox>
                        </VBox>

                        <!-- Boutons d'action -->
                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
                            <Button fx:id="editBtn" text="✏️ Modifier" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                            <Button fx:id="deleteBtn" text="🗑️ Supprimer" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                            <Button fx:id="resourcesBtn" text="📚 Voir les ressources" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>