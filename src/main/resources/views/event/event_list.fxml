<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.event.EventListController"
            style="-fx-background-color: #f3f4f6; -fx-background: #f3f4f6;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #f3f4f6;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <!-- Header -->
                <VBox spacing="0" style="-fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" VBox.vgrow="NEVER">
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #3b82f6, #4f46e5); -fx-background-radius: 16 16 0 0; -fx-padding: 20 25;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="🗓️ Gestion des événements" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                            <Label text="Créer, modifier, supprimer et rechercher des événements." style="-fx-text-fill: #bfdbfe; -fx-font-size: 13px; -fx-padding: 5 0 0 0;"/>
                        </VBox>
                        <Button fx:id="addBtn" text="➕ Nouvel événement" style="-fx-background-color: white; -fx-text-fill: #4f46e5; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
                    </HBox>

                    <!-- Barre de recherche avec bouton Rafraîchir -->
                    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 15 25; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 1 1; -fx-background-radius: 0 0 16 16;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Liste des événements" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                        </VBox>
                        <TextField fx:id="searchField" promptText="🔍 Rechercher par titre ou lieu..." prefWidth="300" style="-fx-padding: 10 15; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;"/>
                        <ComboBox fx:id="sortCombo" prefWidth="150" style="-fx-padding: 8; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="startDate"/>
                                    <String fx:value="endDate"/>
                                    <String fx:value="title"/>
                                    <String fx:value="location"/>
                                    <String fx:value="createdAt"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <ToggleButton fx:id="orderToggle" text="⬇️ Desc" style="-fx-background-radius: 12; -fx-padding: 8 15; -fx-cursor: hand;"/>

                        <!-- ✅ BOUTON RAFRAÎCHIR AJOUTÉ ICI -->
                        <Button fx:id="refreshBtn" text="🔄 Rafraîchir" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 12; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Tableau -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="eventTable" VBox.vgrow="ALWAYS" prefHeight="400" style="-fx-border-color: #e5e7eb; -fx-border-radius: 16;">
                            <columns>
                                <TableColumn fx:id="colTitle" text="Titre" prefWidth="250"/>
                                <TableColumn fx:id="colStartDate" text="Début" prefWidth="180"/>
                                <TableColumn fx:id="colEndDate" text="Fin" prefWidth="180"/>
                                <TableColumn fx:id="colLocation" text="Lieu" prefWidth="200"/>
                                <TableColumn fx:id="colActions" text="Actions" prefWidth="320"/>
                            </columns>
                        </TableView>

                        <!-- Pagination -->
                        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 15; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
                            <Button fx:id="prevBtn" text="◀ Précédent" style="-fx-background-color: #f3f4f6; -fx-padding: 8 15; -fx-background-radius: 12; -fx-cursor: hand;"/>
                            <Label fx:id="pageInfo" text="Chargement..." style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                            <Button fx:id="nextBtn" text="Suivant ▶" style="-fx-background-color: #f3f4f6; -fx-padding: 8 15; -fx-background-radius: 12; -fx-cursor: hand;"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>