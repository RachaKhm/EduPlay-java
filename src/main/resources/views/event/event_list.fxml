<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" stylesheets="@../../css/style.css"
            fx:controller="dev.eduplay.controllers.event.EventListController"
            style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #F8FAFC;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <!-- Header -->
                <VBox spacing="0" styleClass="premium-card" VBox.vgrow="NEVER">
                    <HBox alignment="CENTER_LEFT" styleClass="premium-header" style="-fx-padding: 20 30;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="🗓️ Gestion des événements" styleClass="premium-title"/>
                            <Label text="Créer, modifier, supprimer et rechercher des événements." styleClass="premium-subtitle" style="-fx-padding: 5 0 0 0;"/>
                        </VBox>
                        <Button fx:id="addBtn" text="➕ Nouvel événement" styleClass="btn-secondary"/>
                    </HBox>

                    <!-- Barre de recherche avec bouton Rafraîchir -->
                    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 15 25; -fx-border-color: #e5e7eb; -fx-border-width: 0 1 1 1; -fx-background-radius: 0 0 16 16;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Liste des événements" styleClass="field-label" style="-fx-font-size: 18px;"/>
                        </VBox>
                        <TextField fx:id="searchField" promptText="🔍 Rechercher par titre ou lieu..." prefWidth="300" style="-fx-padding: 10 15; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;"/>
                        <ComboBox fx:id="sortCombo" prefWidth="150" style="-fx-padding: 8; -fx-background-radius: 12; -fx-border-color: #e5e7eb; -fx-border-radius: 12;">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="startDate"/>
                                    <String fx:value="endDate"/>
                                    <String fx:value="title"/>
                                    <String fx:value="location"/>
                                    <String fx:value="createdAt"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <ToggleButton fx:id="orderToggle" text="⬇️ Desc" style="-fx-background-radius: 12; -fx-padding: 8 15; -fx-cursor: hand;"/>

                        <!-- ✅ BOUTON RAFRAÎCHIR AJOUTÉ ICI -->
                        <Button fx:id="refreshBtn" text="🔄 Rafraîchir" styleClass="btn-primary" style="-fx-background-color: linear-gradient(to right, #10B981, #059669);"/>
                    </HBox>
                </VBox>

                <!-- Tableau -->
                <VBox styleClass="premium-card" style="-fx-background-color: white;" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="eventTable" VBox.vgrow="ALWAYS" prefHeight="400" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colTitle" text="Titre" prefWidth="250"/>
                                <TableColumn fx:id="colStartDate" text="Début" prefWidth="180"/>
                                <TableColumn fx:id="colEndDate" text="Fin" prefWidth="180"/>
                                <TableColumn fx:id="colLocation" text="Lieu" prefWidth="200"/>
                                <TableColumn fx:id="colActions" text="Actions" prefWidth="320"/>
                            </columns>
                        </TableView>

                        <!-- Pagination -->
                        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 15; -fx-border-color: #e5e7eb; -fx-border-width: 1 0 0 0;">
                            <Button fx:id="prevBtn" text="◀ Précédent" style="-fx-background-color: #F8FAFC; -fx-padding: 8 15; -fx-background-radius: 12; -fx-cursor: hand;"/>
                            <Label fx:id="pageInfo" text="Chargement..." style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                            <Button fx:id="nextBtn" text="Suivant ▶" style="-fx-background-color: #F8FAFC; -fx-padding: 8 15; -fx-background-radius: 12; -fx-cursor: hand;"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>
