<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.event.RegistrationDetailController"
      spacing="20" alignment="CENTER"
      style="-fx-background-color: #f3f4f6;">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label text="📋 Détails de l'inscription" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
        <Label fx:id="childNameValue" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        <Label fx:id="statusValue" style="-fx-font-size: 14px;"/>
        <Label fx:id="registeredAtValue" style="-fx-font-size: 14px; -fx-text-fill: #6b7280;"/>
        <Label fx:id="eventValue" style="-fx-font-size: 14px;"/>
        <Label fx:id="phoneValue" style="-fx-font-size: 14px;"/>
    </VBox>

    <Button fx:id="backBtn" text="← Retour" style="-fx-background-color: #e2e8f0; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
</VBox>