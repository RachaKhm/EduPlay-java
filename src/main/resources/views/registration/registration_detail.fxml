<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.event.RegistrationDetailController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color: #f3f4f6;">

    <padding>
        <Insets top="25" right="35" bottom="25" left="35"/>
    </padding>

    <children>
        <Button fx:id="backBtn" text="← Retour à la liste"
                style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"
                maxWidth="150"/>

        <Label text="📋 Détails de l'inscription" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
            <children>
                <VBox spacing="5">
                    <Label text="📅 Événement" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                    <Label fx:id="eventValue" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;" wrapText="true"/>
                </VBox>

                <Separator/>

                <VBox spacing="5">
                    <Label text="👶 Enfant" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                    <Label fx:id="childNameValue" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="📞 Téléphone parent" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                    <Label fx:id="phoneValue" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="📅 Date d'inscription" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>

                    <Label fx:id="registeredAtValue" style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                </VBox>

                <VBox fx:id="qrBox" spacing="5" visible="false" managed="false">
                    <Label text="🎫 QR Code" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                    <ImageView fx:id="qrCodeImageView" fitHeight="150" fitWidth="150" preserveRatio="true"/>
                    <Label fx:id="qrCodeMessage" style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
                </VBox>

                <VBox fx:id="scannedBox" spacing="5" visible="false" managed="false">
                    <Label text="✅ Scanné le" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                    <Label fx:id="scannedAtValue" style="-fx-font-size: 13px; -fx-text-fill: #10b981;"/>
                </VBox>
            </children>
        </VBox>

        <HBox spacing="15" alignment="CENTER">
            <Button fx:id="editBtn" text="✏️ Modifier"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </HBox>
    </children>
</VBox>