<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.parent.ParentOrderFormController"
      spacing="12" alignment="TOP_CENTER" style="-fx-background-color: #f8f9fa; -fx-padding:20;">

    <Label fx:id="lblTitle" text="Produit" style="-fx-font-size:20px; -fx-font-weight:bold;"/>
    <Label fx:id="lblPrice" text="Prix" style="-fx-text-fill:#6b7280;"/>

    <GridPane hgap="8" vgap="8">
        <Label text="Quantité:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="txtQuantity" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <!-- Adresse de livraison retirée du formulaire -->
    </GridPane>

    <HBox spacing="8">
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Annuler" onAction="#handleCancel" />
        <Button text="Commander" onAction="#handlePlaceOrder" />
    </HBox>

</VBox>

