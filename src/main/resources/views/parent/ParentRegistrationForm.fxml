<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.parent.ParentRegistrationController"
            style="-fx-background-color: #f8f9fa; -fx-background: #f8f9fa;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #f8f9fa;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <Button fx:id="backBtn" text="← Retour à l'événement" style="-fx-background-color: transparent; -fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-padding: 8 0; -fx-cursor: hand;"/>

                <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2); -fx-padding: 24;">
                    <Label text="📝 Inscription" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                    <Label fx:id="eventTitleLabel" style="-fx-font-size: 14px; -fx-text-fill: #8b5cf6;"/>

                    <Separator/>

                    <Label text="Nom complet de l'enfant *" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="childNameField" promptText="Ex: Lina Ben Ali"/>

                    <Label text="Téléphone parent *" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="parentPhoneField" promptText="Ex: 55123456"/>

                    <Label text="Niveau / Classe" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="classLevelField" promptText="Ex: CE2"/>

                    <Label text="Notes médicales" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextArea fx:id="medicalNotesArea" promptText="Allergies, traitements, etc..." prefHeight="60" wrapText="true"/>

                    <Label text="Contact d'urgence - Nom" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="emergencyNameField" promptText="Ex: Ahmed Ben Ali"/>

                    <Label text="Contact d'urgence - Téléphone" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="emergencyPhoneField" promptText="Ex: 98765432"/>

                    <Label text="Notes supplémentaires" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextArea fx:id="notesArea" prefHeight="60" wrapText="true"/>

                    <Label fx:id="messageLabel" wrapText="true" style="-fx-font-size: 13px;"/>

                    <Button fx:id="submitBtn" text="Confirmer l'inscription" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 30; -fx-cursor: hand; -fx-font-size: 14px;" maxWidth="Infinity"/>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>