<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/20.0.2"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.ParentDashboardController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color: #f3f4f6;">

    <padding>
        <Insets top="25" right="35" bottom="25" left="35"/>
    </padding>

    <children>
        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="👨‍👩‍👧 Mon espace parent" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label fx:id="welcomeLabel" text="Bienvenue" style="-fx-text-fill: #64748b; -fx-font-size: 14px;"/>
            </VBox>

            <!-- Badge de notification - Version corrigée -->
            <StackPane>
                <Label text="🔔" style="-fx-font-size: 22px; -fx-cursor: hand;"/>
                <Label fx:id="notificationBadge" text="0"
                       style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 10px; -fx-padding: 2 5; -fx-background-radius: 10;"
                       visible="false" managed="false">
                    <StackPane.margin>
                        <Insets top="-5" right="-5"/>
                    </StackPane.margin>
                </Label>
            </StackPane>
        </HBox>

        <!-- Grille des actions rapides -->
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
                <ColumnConstraints percentWidth="33.33"/>
            </columnConstraints>

            <!-- Carte Événements -->
            <VBox GridPane.columnIndex="0" spacing="10" onMouseClicked="#showEvents"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-cursor: hand;">
                <Label text="📅" style="-fx-font-size: 32px;"/>
                <Label text="Événements" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Découvrez les activités" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            </VBox>

            <!-- Carte Inscriptions -->
            <VBox GridPane.columnIndex="1" spacing="10" onMouseClicked="#showRegistrations"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-cursor: hand;">
                <Label text="📋" style="-fx-font-size: 32px;"/>
                <Label text="Mes inscriptions" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Suivez vos réservations" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            </VBox>

            <!-- Carte Enfants -->
            <VBox GridPane.columnIndex="2" spacing="10" onMouseClicked="#showChildren"
                  style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-cursor: hand;">
                <Label text="👶" style="-fx-font-size: 32px;"/>
                <Label text="Mes enfants" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Gérez les profils" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
            </VBox>
        </GridPane>

        <!-- Section Notifications -->
        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
                <Label text="📢 Notifications" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <Button fx:id="clearAllBtn" text="✓ Tout marquer comme lu"
                        style="-fx-background-color: transparent; -fx-text-fill: #3b82f6; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 5 10;"/>
            </HBox>

            <Separator/>

            <ScrollPane fx:id="notificationsScrollPane" fitToWidth="true"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="notificationsContainer" spacing="10"
                      style="-fx-background-color: transparent; -fx-padding: 5;"/>
            </ScrollPane>
        </VBox>
    </children>
</VBox>