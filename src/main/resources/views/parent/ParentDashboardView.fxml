<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.ParentDashboardController"
      spacing="0" 
      stylesheets="@../../styles/parent.css"
      styleClass="parent-container">
    <HBox style="-fx-padding: 0 0 32 0;">
        <VBox spacing="8">
            <Label text="Espace Parent"
                   styleClass="parent-title"/>
            <Label fx:id="subtitleLabel" text="Gérez la famille et vos abonnements"
                   styleClass="parent-section-subtitle"/>
        </VBox>
    </HBox>
    <HBox spacing="24">
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              styleClass="parent-stat-card">
            <Label text="Mes enfants" styleClass="parent-stat-label"/>
            <Label fx:id="totalChildrenLabel" text="—"
                   styleClass="parent-stat-value" style="-fx-text-fill: #3B82F6;"/>
        </VBox>
        <VBox spacing="10" HBox.hgrow="ALWAYS"
              styleClass="parent-stat-card">
            <Label text="Événements à venir" styleClass="parent-stat-label"/>
            <Label fx:id="totalEventsLabel" text="—"
                   styleClass="parent-stat-value" style="-fx-text-fill: #10B981;"/>
        </VBox>
    </HBox>
</VBox>
