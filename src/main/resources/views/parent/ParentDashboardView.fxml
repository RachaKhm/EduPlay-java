<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.ParentDashboardController"
      spacing="0" style="-fx-background-color: #F8FAFC;">

    <!-- Gradient Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #10B981, #0EA5E9); -fx-padding: 28 28 24 28;" spacing="4">
        <Label fx:id="welcomeLabel" text="Espace Parent"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label fx:id="subtitleLabel" text="Gérez la scolarité de vos enfants"
               style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.85);"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox spacing="22" style="-fx-padding: 22 24 30 24;">

            <!-- Stats Row -->
            <HBox spacing="16">
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12;
                             -fx-border-color: #DBEAFE; -fx-border-width: 2; -fx-border-radius: 12;
                             -fx-effect: dropshadow(three-pass-box, rgba(59,130,246,0.08), 8, 0, 0, 4);">
                    <Label fx:id="totalChildrenLabel" text="—"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #3B82F6;"/>
                    <Label text="👨‍👧‍👦 Mes enfants" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12;
                             -fx-border-color: #D1FAE5; -fx-border-width: 2; -fx-border-radius: 12;
                             -fx-effect: dropshadow(three-pass-box, rgba(16,185,129,0.08), 8, 0, 0, 4);">
                    <Label fx:id="totalSeancesLabel" text="—"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                    <Label text="📅 Séances inscrites" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-padding: 18; -fx-background-radius: 12;
                             -fx-border-color: #EDE9FE; -fx-border-width: 2; -fx-border-radius: 12;
                             -fx-effect: dropshadow(three-pass-box, rgba(139,92,246,0.08), 8, 0, 0, 4);">
                    <Label fx:id="totalCoursesLabel" text="—"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8B5CF6;"/>
                    <Label text="📚 Cours actifs" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                </VBox>
            </HBox>

            <!-- Kids' Séances Section -->
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT">
                    <Label text="📅 Séances de vos enfants"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" HBox.hgrow="ALWAYS"/>
                </HBox>
                <VBox fx:id="kidsSeancesContainer" spacing="10">
                    <Label text="Chargement..." style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
                </VBox>
            </VBox>

            <!-- Groq AI Recommendation Section -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 14;
                         -fx-border-color: #E2E8F0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 8, 0, 0, 4);">

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🤖 Recommandations IA (Groq)"
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" HBox.hgrow="ALWAYS"/>
                    <Label text="Llama 3.1" style="-fx-font-size: 11px; -fx-text-fill: #8B5CF6;
                                -fx-background-color: #EDE9FE; -fx-padding: 2 8; -fx-background-radius: 999;"/>
                </HBox>

                <Label text="Demandez à l'IA quelle séance recommander pour vos enfants :"
                       style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>

                <TextArea fx:id="aiPromptField" prefRowCount="2" wrapText="true"
                          promptText="Ex : Mon enfant est en CM2 et aime les maths. Quelle séance lui recommandes-tu ?"
                          style="-fx-background-radius: 10; -fx-border-radius: 10;
                                 -fx-border-color: #E2E8F0; -fx-padding: 10; -fx-font-size: 13px;"/>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="aiAskBtn" text="✨ Demander à l'IA"
                            style="-fx-background-color: linear-gradient(to right, #8B5CF6, #3B82F6);
                                   -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
                </HBox>

                <!-- AI Response Box -->
                <VBox fx:id="aiResponseBox" spacing="8" managed="false" visible="false"
                      style="-fx-background-color: #F5F3FF; -fx-padding: 16; -fx-background-radius: 10;
                             -fx-border-color: #DDD6FE; -fx-border-width: 1; -fx-border-radius: 10;">
                    <Label text="💬 Réponse de l'IA :"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #7C3AED;"/>
                    <Label fx:id="aiResponseLabel" text="" wrapText="true"
                           style="-fx-font-size: 13px; -fx-text-fill: #3730A3;"/>
                </VBox>

                <Label fx:id="aiLoadingLabel" text="⏳ Consultation de l'IA en cours..."
                       managed="false" visible="false"
                       style="-fx-font-size: 13px; -fx-text-fill: #8B5CF6; -fx-font-style: italic;"/>
                <Label fx:id="aiErrorLabel" text="" managed="false" visible="false"
                       style="-fx-font-size: 12px; -fx-text-fill: #EF4444;" wrapText="true"/>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>
