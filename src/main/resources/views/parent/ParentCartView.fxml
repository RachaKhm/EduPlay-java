<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.parent.ParentCartController"
      spacing="24"
      stylesheets="@/styles/admin.css"
      style="-fx-background-color: transparent;">

    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <!-- HEADER -->
    <VBox spacing="4">
        <Label text="🛒 Mon Panier" styleClass="page-title"/>
        <Label text="Vérifiez vos produits avant de passer commande" styleClass="page-subtitle"/>
    </VBox>

    <HBox spacing="24" VBox.vgrow="ALWAYS">
        <!-- LIST AREA -->
        <VBox spacing="16" HBox.hgrow="ALWAYS" styleClass="card">
            <ListView fx:id="cartListView" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent;"/>
        </VBox>

        <!-- SUMMARY AREA -->
        <VBox spacing="20" prefWidth="300" styleClass="card" alignment="TOP_CENTER">
            <Label text="Récapitulatif" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #1E293B;"/>
            
            <Separator />
            
            <HBox alignment="CENTER_LEFT">
                <Label text="Total" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblTotal" text="0.000 DT" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #10B981;"/>
            </HBox>
            
            <VBox VBox.vgrow="ALWAYS" />
            
            <Button text="Passer la commande" 
                    onAction="#handleCheckout" 
                    maxWidth="Infinity" 
                    styleClass="btn-save" 
                    style="-fx-padding: 15; -fx-font-size: 15px;"/>
                    
            <Button text="Vider le panier" 
                    onAction="#handleClear" 
                    maxWidth="Infinity" 
                    styleClass="btn-cancel" 
                    style="-fx-padding: 10;"/>
        </VBox>
    </HBox>

</VBox>
