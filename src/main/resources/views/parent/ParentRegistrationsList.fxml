<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.parent.ParentRegistrationsListController"
      spacing="20" alignment="TOP_CENTER"
      style="-fx-background-color: #f8f9fa;">

    <padding>
        <Insets top="25" right="35" bottom="25" left="35"/>
    </padding>

    <children>
        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="📋 Mes inscriptions" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
                <Label text="Suivez vos inscriptions aux événements"
                       style="-fx-text-fill: #9999BB; -fx-font-size: 14px; -fx-padding: 5 0 0 0;"/>
            </VBox>
            <Button fx:id="backToEventsBtn" text="← Voir les événements" style="-fx-background-color: transparent; -fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>

        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="12">
                    <VBox fx:id="registrationsContainer" spacing="12"/>
                    <Label fx:id="emptyLabel" text="Aucune inscription pour le moment" style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" visible="false" managed="false"/>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>