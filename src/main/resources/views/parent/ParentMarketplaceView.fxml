<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.parent.ParentMarketplaceController"
      spacing="24"
      stylesheets="@/styles/admin.css"
      style="-fx-background-color: transparent;">

    <padding>
        <Insets top="20" right="35" bottom="20" left="35"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="🛒 Marketplace" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
            <Label text="Découvrez et commandez les produits disponibles." style="-fx-text-fill: #9999BB; -fx-font-size: 14px; -fx-padding: 5 0 0 0;"/>
        </VBox>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 12 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.04), 10, 0, 0, 2);">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un produit..." prefWidth="300" style="-fx-padding:8 12; -fx-background-radius:25; -fx-border-color:#e2e8f0; -fx-border-radius:25;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="resultCountLabel" text="0 résultat(s)" style="-fx-text-fill:#6b7280; -fx-font-size:13px;"/>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
        <content>
            <FlowPane fx:id="productsGrid" hgap="20" vgap="20" alignment="TOP_CENTER" />
        </content>
    </ScrollPane>

</VBox>

