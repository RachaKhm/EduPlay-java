<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.parent.ParentMarketplaceController"
      spacing="20" alignment="TOP_CENTER" styleClass="marketplace-root" stylesheets="@/styles/parent-marketplace.css">

    <padding>
        <Insets top="20" right="35" bottom="20" left="35"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="market-header">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="🛒 Marketplace" styleClass="market-title"/>
            <Label text="Découvrez et commandez les produits disponibles." styleClass="market-subtitle"/>
        </VBox>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="market-search">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un produit..." prefWidth="360" styleClass="form-field" />
        <ComboBox fx:id="sortBox" prefWidth="200" promptText="Trier" styleClass="form-field" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="resultCountLabel" text="0 résultat(s)" style="-fx-text-fill:#6b7280; -fx-font-size:13px;"/>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
        <content>
            <FlowPane fx:id="productsGrid" styleClass="flow-pane products-grid" alignment="TOP_CENTER" />
        </content>
    </ScrollPane>

</VBox>


