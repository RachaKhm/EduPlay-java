<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.parent.ParentOrdersController"
      spacing="0" style="-fx-background-color: #F8FAFC;">

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #10B981, #0EA5E9); -fx-padding: 24 28 20 28;">
        <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="🧾 Mes commandes" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label fx:id="subtitleLabel" text="Liste de vos commandes" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.85);"/>
                    </VBox>
                    <Button text="Chat" onAction="#openChat" style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-border-radius: 8; -fx-background-radius:8;"/>
        </HBox>
    </VBox>

    <!-- Search Bar -->
    <HBox style="-fx-padding: 14 20 0 20;">
        <TextField fx:id="searchField" promptText="🔍 Rechercher par produit ou id..."
                   style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #E2E8F0; -fx-padding: 10 14; -fx-background-color: white;"
                   HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Orders list (card style) -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox fx:id="ordersContainer" spacing="14" style="-fx-padding: 20;">
            <Label text="Chargement..." style="-fx-text-fill: #94A3B8; -fx-font-size: 14px;"/>
        </VBox>
    </ScrollPane>

    <HBox spacing="8" alignment="CENTER_RIGHT" style="-fx-padding: 12 20 18 20;">
        <Button text="Rafraîchir" onAction="#handleRefresh" />
        <Button text="Retour" onAction="#handleBack" />
    </HBox>

</VBox>

