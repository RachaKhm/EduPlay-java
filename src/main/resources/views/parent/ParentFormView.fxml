<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.ParentDashboardController"
            prefWidth="620"
            style="-fx-background-color: #F8F9FA;">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1A1A2E; -fx-padding: 18 24;">
            <VBox spacing="3">
                <Label fx:id="formTitle" text="Nouveau parent"
                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Compte parent + enfants rattachés"
                       style="-fx-font-size: 11px; -fx-text-fill: #555577;"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#closeForm"
                    style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                           -fx-font-size: 16px; -fx-cursor: hand; -fx-border-width: 0;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="0" style="-fx-padding: 24 32 24 32; -fx-background-color: #F8F9FA;">

                <!-- Section : Informations parent -->
                <Label text="Informations du parent"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                              -fx-text-fill: #9999BB; -fx-padding: 0 0 12 0;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Prénom *"
                               style="-fx-font-size: 12px; -fx-text-fill: #555577; -fx-font-weight: bold;"/>
                        <TextField fx:id="firstNameField" promptText="ex: Fatma"
                                   style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                          -fx-border-width: 1; -fx-background-radius: 6;
                                          -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nom *"
                               style="-fx-font-size: 12px; -fx-text-fill: #555577; -fx-font-weight: bold;"/>
                        <TextField fx:id="lastNameField" promptText="ex: Trabelsi"
                                   style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                          -fx-border-width: 1; -fx-background-radius: 6;
                                          -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" style="-fx-padding: 14 0 0 0;">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Email *"
                               style="-fx-font-size: 12px; -fx-text-fill: #555577; -fx-font-weight: bold;"/>
                        <TextField fx:id="emailField" promptText="parent@email.com"
                                   style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                          -fx-border-width: 1; -fx-background-radius: 6;
                                          -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Téléphone"
                               style="-fx-font-size: 12px; -fx-text-fill: #555577; -fx-font-weight: bold;"/>
                        <TextField fx:id="telephoneField" promptText="+216 XX XXX XXX"
                                   style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                          -fx-border-width: 1; -fx-background-radius: 6;
                                          -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                    </VBox>
                </HBox>

                <VBox spacing="6" style="-fx-padding: 14 0 0 0;">
                    <Label text="Adresse"
                           style="-fx-font-size: 12px; -fx-text-fill: #555577; -fx-font-weight: bold;"/>
                    <TextField fx:id="adresseField" promptText="Adresse complète"
                               style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                      -fx-border-width: 1; -fx-background-radius: 6;
                                      -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                </VBox>

                <HBox spacing="16" style="-fx-padding: 14 0 0 0;">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Mot de passe *"
                               style="-fx-font-size: 12px; -fx-text-fill: #555577; -fx-font-weight: bold;"/>
                        <PasswordField fx:id="passwordField" promptText="Minimum 8 caractères"
                                       style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                              -fx-border-width: 1; -fx-background-radius: 6;
                                              -fx-border-radius: 6; -fx-padding: 9 12; -fx-font-size: 13px;"/>
                    </VBox>
                    <VBox spacing="6" alignment="BOTTOM_LEFT" HBox.hgrow="ALWAYS">
                        <CheckBox fx:id="activeCheck" text="Compte actif" selected="true"
                                  style="-fx-font-size: 13px; -fx-text-fill: #444466; -fx-padding: 0 0 10 0;"/>
                    </VBox>
                </HBox>

                <Separator style="-fx-padding: 20 0 0 0;"/>

                <!-- Section : Enfants rattachés -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0 12 0;">
                    <Label text="Enfants rattachés"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9999BB;"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button text="+ Ajouter un enfant" onAction="#addChildRow"
                            style="-fx-background-color: #F0F5FF; -fx-text-fill: #4A90D9;
                                   -fx-font-size: 12px; -fx-padding: 6 14;
                                   -fx-background-radius: 5; -fx-border-color: #C0D0F8;
                                   -fx-border-width: 1; -fx-border-radius: 5; -fx-cursor: hand;"/>
                </HBox>

                <!-- Table des enfants -->
                <VBox fx:id="childrenContainer" spacing="8"
                      style="-fx-background-color: white; -fx-padding: 16;
                             -fx-background-radius: 8; -fx-border-color: #E8E8F0;
                             -fx-border-width: 1; -fx-border-radius: 8;">

                    <!-- En-tête colonnes -->
                    <HBox spacing="8"
                          style="-fx-padding: 0 0 10 0;
                                 -fx-border-color: #F0F0F8; -fx-border-width: 0 0 1 0;">
                        <Label text="Prénom" prefWidth="120"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9999BB;"/>
                        <Label text="Nom" prefWidth="120"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9999BB;"/>
                        <Label text="Niveau" prefWidth="130"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9999BB;"/>
                        <Label text="Username" prefWidth="110"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9999BB;"/>
                        <Label text="" prefWidth="32"/>
                    </HBox>

                    <!-- Ligne enfant 1 (par défaut) -->
                    <HBox fx:id="childRow1" spacing="8" alignment="CENTER_LEFT">
                        <TextField promptText="Prénom" prefWidth="120"
                                   style="-fx-background-color: #F8F9FA; -fx-border-color: #DDDDE8;
                                          -fx-border-width: 1; -fx-background-radius: 5;
                                          -fx-border-radius: 5; -fx-padding: 7 10; -fx-font-size: 12px;"/>
                        <TextField promptText="Nom" prefWidth="120"
                                   style="-fx-background-color: #F8F9FA; -fx-border-color: #DDDDE8;
                                          -fx-border-width: 1; -fx-background-radius: 5;
                                          -fx-border-radius: 5; -fx-padding: 7 10; -fx-font-size: 12px;"/>
                        <ComboBox prefWidth="130"
                                  style="-fx-font-size: 12px;"/>
                        <TextField promptText="username" prefWidth="110"
                                   style="-fx-background-color: #F8F9FA; -fx-border-color: #DDDDE8;
                                          -fx-border-width: 1; -fx-background-radius: 5;
                                          -fx-border-radius: 5; -fx-padding: 7 10; -fx-font-size: 12px;"/>
                        <Button text="✕" prefWidth="32"
                                style="-fx-background-color: #FFF0F0; -fx-text-fill: #E94560;
                                       -fx-background-radius: 5; -fx-border-width: 0;
                                       -fx-font-size: 11px; -fx-cursor: hand;"/>
                    </HBox>

                    <Label fx:id="noChildrenLabel" text="Aucun enfant ajouté."
                           managed="false" visible="false"
                           style="-fx-font-size: 12px; -fx-text-fill: #AAAACC;
                                  -fx-padding: 4 0;"/>
                </VBox>

                <!-- Feedback -->
                <Label fx:id="feedbackLabel" text="" wrapText="true"
                       style="-fx-font-size: 12px; -fx-padding: 12 0 0 0; -fx-text-fill: #2E9E6E;"/>

                <!-- Boutons -->
                <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 24 0 0 0;">
                    <Button text="Annuler" onAction="#closeForm"
                            style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                   -fx-border-width: 1; -fx-border-radius: 6;
                                   -fx-background-radius: 6; -fx-text-fill: #555577;
                                   -fx-font-size: 13px; -fx-padding: 9 20; -fx-cursor: hand;"/>
                    <Button text="Enregistrer le parent" onAction="#saveParent"
                            style="-fx-background-color: #E94560; -fx-text-fill: white;
                                   -fx-font-size: 13px; -fx-font-weight: bold;
                                   -fx-padding: 9 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
