<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.ParentFormController"
            prefWidth="620"
            stylesheets="@../../styles/parent.css"
            styleClass="parent-scroll-pane">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              styleClass="parent-header">
            <VBox spacing="3">
                <Label fx:id="formTitle" text="Nouveau parent"
                       styleClass="parent-header-title"/>
                <Label text="Compte parent + enfants rattachés"
                       styleClass="parent-header-subtitle"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#closeForm"
                    styleClass="parent-close-btn"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="parent-scroll-pane">
            <VBox spacing="0" styleClass="parent-form-content">

                <!-- Section : Informations parent -->
                <Label text="Informations du parent"
                       styleClass="parent-section-label" style="-fx-padding: 0 0 12 0;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Prénom *"
                               styleClass="parent-label"/>
                        <TextField fx:id="firstNameField" promptText="ex: Fatma"
                                   styleClass="parent-input"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nom *"
                               styleClass="parent-label"/>
                        <TextField fx:id="lastNameField" promptText="ex: Trabelsi"
                                   styleClass="parent-input"/>
                    </VBox>
                </HBox>

                <HBox spacing="16" style="-fx-padding: 14 0 0 0;">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Email *"
                               styleClass="parent-label"/>
                        <TextField fx:id="emailField" promptText="parent@email.com"
                                   styleClass="parent-input"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Téléphone"
                               styleClass="parent-label"/>
                        <TextField fx:id="telephoneField" promptText="+216 XX XXX XXX"
                                   styleClass="parent-input"/>
                    </VBox>
                </HBox>

                <VBox spacing="6" style="-fx-padding: 14 0 0 0;">
                    <Label text="Adresse"
                           styleClass="parent-label"/>
                    <TextField fx:id="adresseField" promptText="Adresse complète"
                               styleClass="parent-input"/>
                </VBox>

                <HBox spacing="16" style="-fx-padding: 14 0 0 0;">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Mot de passe *"
                               styleClass="parent-label"/>
                        <PasswordField fx:id="passwordField" promptText="Minimum 8 caractères"
                                       styleClass="parent-input"/>
                    </VBox>
                    <VBox spacing="6" alignment="BOTTOM_LEFT" HBox.hgrow="ALWAYS">
                        <CheckBox fx:id="activeCheck" text="Compte actif" selected="true"
                                  style="-fx-font-size: 13px; -fx-text-fill: #444466; -fx-padding: 0 0 10 0;"/>
                    </VBox>
                </HBox>

                <Separator style="-fx-padding: 20 0 0 0;"/>

                <!-- Section : Enfants rattachés -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 18 0 12 0;">
                    <Label text="Enfants rattachés"
                           styleClass="parent-section-label" style="-fx-padding: 0;"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Button text="+ Ajouter un enfant" onAction="#addChildRow"
                            styleClass="parent-btn-add-child"/>
                </HBox>

                <!-- Table des enfants -->
                <VBox fx:id="childrenContainer" spacing="8"
                      styleClass="parent-card" style="-fx-padding: 16;">

                    <!-- En-tête colonnes -->
                    <HBox spacing="8"
                          styleClass="parent-table-header" style="-fx-padding: 0 0 10 0; -fx-background-color: transparent;">
                        <Label text="Prénom" prefWidth="120"
                               styleClass="parent-table-header-label"/>
                        <Label text="Nom" prefWidth="120"
                               styleClass="parent-table-header-label"/>
                        <Label text="Niveau" prefWidth="130"
                               styleClass="parent-table-header-label"/>
                        <Label text="Username" prefWidth="110"
                               styleClass="parent-table-header-label"/>
                        <Label text="" prefWidth="32"/>
                    </HBox>

                    <!-- Ligne enfant 1 (par défaut) -->
                    <HBox fx:id="childRow1" spacing="8" alignment="CENTER_LEFT">
                        <TextField promptText="Prénom" prefWidth="120"
                                   styleClass="parent-input" style="-fx-font-size: 12px; -fx-padding: 7 10;"/>
                        <TextField promptText="Nom" prefWidth="120"
                                   styleClass="parent-input" style="-fx-font-size: 12px; -fx-padding: 7 10;"/>
                        <ComboBox prefWidth="130"
                                  style="-fx-font-size: 12px;"/>
                        <TextField promptText="username" prefWidth="110"
                                   styleClass="parent-input" style="-fx-font-size: 12px; -fx-padding: 7 10;"/>
                        <Button text="✕" prefWidth="32"
                                styleClass="parent-row-delete-btn"/>
                    </HBox>

                    <Label fx:id="noChildrenLabel" text="Aucun enfant ajouté."
                           managed="false" visible="false"
                           styleClass="stat-sublabel" style="-fx-padding: 4 0; -fx-font-size: 12px;"/>
                </VBox>

                <!-- Feedback -->
                <Label fx:id="feedbackLabel" text="" wrapText="true"
                       styleClass="parent-success-label"/>

                <!-- Boutons -->
                <HBox spacing="12" alignment="CENTER_RIGHT" styleClass="parent-button-container">
                    <Button text="Annuler" onAction="#closeForm"
                            styleClass="parent-btn-secondary" style="-fx-font-size: 13px; -fx-padding: 9 20;"/>
                    <Button text="Enregistrer le parent" onAction="#saveParent"
                            styleClass="parent-btn-primary" style="-fx-font-size: 13px; -fx-padding: 9 24;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
