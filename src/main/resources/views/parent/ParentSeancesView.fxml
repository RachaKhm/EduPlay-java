<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.parent.ParentSeancesController"
      spacing="0" style="-fx-background-color: #F8FAFC;">

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #10B981, #0EA5E9); -fx-padding: 24 28 20 28;">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Séances disponibles"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="subtitleLabel" text="Inscrivez vos enfants aux séances de cours"
                       style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.85);"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Info banner -->
    <HBox style="-fx-background-color: #FFF7ED; -fx-padding: 12 20; -fx-border-color: #FED7AA; -fx-border-width: 0 0 1 0;">
        <Label text="💡 Cliquez '✅ Inscrire mon enfant' pour enregistrer un enfant à une séance."
               style="-fx-font-size: 13px; -fx-text-fill: #92400E;"/>
    </HBox>

    <!-- Séances list -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox fx:id="seancesContainer" spacing="14" style="-fx-padding: 20;">
            <Label text="Chargement..." style="-fx-text-fill: #94A3B8; -fx-font-size: 14px;"/>
        </VBox>
    </ScrollPane>

</VBox>
