<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>

<ScrollPane xmlns="http://javafx.com/javafx/20.0.2" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.parent.ParentRegistrationDetailController"
            style="-fx-background-color: #f8f9fa; -fx-background: #f8f9fa;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #f8f9fa;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <Button fx:id="backBtn" text="← Retour à mes inscriptions"
                        style="-fx-background-color: transparent; -fx-text-fill: #8b5cf6; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 8 0; -fx-cursor: hand;"/>

                <VBox spacing="0" style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 2);">
                    <VBox spacing="16" style="-fx-padding: 24;">
                        <Label text="🎫 Mon ticket d'entrée" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label fx:id="eventTitleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>

                        <Separator/>

                        <GridPane hgap="16" vgap="12">
                            <Label text="👶 Enfant :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <Label fx:id="childNameLabel" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-text-fill: #1e293b;"/>

                            <Label text="📅 Date :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <Label fx:id="dateLabel" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-text-fill: #1e293b;"/>

                            <Label text="📍 Lieu :" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <Label fx:id="locationLabel" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-text-fill: #1e293b;" wrapText="true"/>
                        </GridPane>

                        <Separator/>

                        <Label text="📱 QR Code d'entrée" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                        <VBox alignment="CENTER" spacing="10">
                            <ImageView fx:id="qrCodeImageView" fitHeight="200" fitWidth="200" preserveRatio="true"/>
                            <Label fx:id="qrMessageLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                        </VBox>

                        <Label fx:id="infoLabel" style="-fx-text-fill: #10b981; -fx-font-size: 13px;" wrapText="true"/>
                    </VBox>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>