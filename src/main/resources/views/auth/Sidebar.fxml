<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.SidebarController"
      prefWidth="230" spacing="4"
      style="-fx-background-color: #1A1A2E; -fx-padding: 0;">

    <!-- Logo -->
    <VBox alignment="CENTER_LEFT"
          style="-fx-padding: 22 20 18 20; -fx-border-color: #2A2A4E;
                 -fx-border-width: 0 0 1 0;">
        <Label text="EduPlay"
               style="-fx-text-fill: #E94560; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        <Label text="Espace de gestion"
               style="-fx-text-fill: #444466; -fx-font-size: 10px;"/>
    </VBox>

    <!-- Profil utilisateur connecté -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-padding: 16 20; -fx-border-color: #2A2A4E;
                 -fx-border-width: 0 0 1 0; -fx-cursor: hand;"
          onMouseClicked="#showProfile">
        <StackPane prefWidth="36" prefHeight="36">
            <Circle radius="18" fill="#2A1A2E"/>
            <Circle radius="18" fill="transparent" stroke="#E94560" strokeWidth="1.5"/>
            <Label text="U"
                   style="-fx-text-fill: #E94560; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </StackPane>
        <VBox spacing="2">
            <Label fx:id="labelUserName" text="Utilisateur"
                   style="-fx-text-fill: #DDDDEE; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            <Label fx:id="labelUserRole" text="Rôle"
                   style="-fx-text-fill: #E94560; -fx-font-size: 10px;"/>
        </VBox>
    </HBox>

    <!-- Navigation -->
    <VBox spacing="2" style="-fx-padding: 12 10 0 10;" VBox.vgrow="ALWAYS">

        <Label text="NAVIGATION"
               style="-fx-text-fill: #333355; -fx-font-size: 9px;
                      -fx-font-weight: bold; -fx-padding: 4 8 6 8;"/>

        <!-- Commun tous rôles -->
        <Button fx:id="btnDashboard" text="  Tableau de bord"
                onAction="#showDashboard" maxWidth="Infinity"
                style="-fx-background-color: #E94560; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-background-radius: 8;
                       -fx-alignment: CENTER_LEFT; -fx-padding: 10 16;
                       -fx-cursor: hand; -fx-border-width: 0;"/>

        <!-- ADMIN -->
        <Button fx:id="btnUsers" text="  Utilisateurs"
                onAction="#showUsers" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <Button fx:id="btnAdminCourses" text="  Cours"
                onAction="#showAdminCourses" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <Button fx:id="btnAdminSeances" text="  Séances"
                onAction="#showAdminSeances" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>
        <Button fx:id="btnAdminCalendar" text="  Calendar"
                onAction="#showAdminCalendar" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>
        <Button fx:id="btnAdminStats" text="  Statistiques"
                onAction="#showAdminStats" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <!-- ENSEIGNANT -->
        <Button fx:id="btnCourses" text="  Mes cours"
                onAction="#showTeacherCourses" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <Button fx:id="btnStudents" text="  Mes élèves"
                onAction="#showStudents" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <!-- PARENT -->
        <Button fx:id="btnChildren" text="  Mes enfants"
                onAction="#showChildren" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <Button fx:id="btnParentCourses" text="  Cours"
                onAction="#showParentCourses" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <Button fx:id="btnEvents" text="  Événements"
                onAction="#showEvents" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <!-- ENFANT -->
        <Button fx:id="btnMyCoursesChild" text="  Mes cours"
                onAction="#showMyCoursesChild" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <Button fx:id="btnGames" text="  Jeux éducatifs"
                onAction="#showGames" maxWidth="Infinity"
                visible="false" managed="false"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>

        <Separator style="-fx-padding: 8 0; -fx-opacity: 0.2;"/>

        <Label text="COMPTE"
               style="-fx-text-fill: #333355; -fx-font-size: 9px;
                      -fx-font-weight: bold; -fx-padding: 4 8 6 8;"/>

        <Button fx:id="btnProfile" text="  Mon profil"
                onAction="#showProfile" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #AAAACC;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 10 16; -fx-cursor: hand; -fx-border-width: 0;"/>
    </VBox>

    <!-- Déconnexion -->
    <VBox style="-fx-padding: 10; -fx-border-color: #2A2A4E; -fx-border-width: 1 0 0 0;">
        <Button fx:id="btnLogout" text="  Déconnexion"
                onAction="#handleLogout" maxWidth="Infinity"
                style="-fx-background-color: transparent; -fx-text-fill: #555577;
                       -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                       -fx-padding: 9 16; -fx-cursor: hand; -fx-border-width: 0;
                       -fx-font-size: 12px;"/>
    </VBox>

</VBox>
