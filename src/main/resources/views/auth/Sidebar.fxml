<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.SidebarController"
      styleClass="sidebar"
      spacing="0"
      prefWidth="230">

    <VBox alignment="CENTER"
          style="-fx-padding: 28 20 22 20;
                 -fx-border-color: #2A2A4E; -fx-border-width: 0 0 1 0;">
        <Label text="EduPlay" styleClass="sidebar-logo-title"/>
        <Label text="Administration"  styleClass="sidebar-logo-subtitle"/>
    </VBox>

    <VBox spacing="2" style="-fx-padding: 14 10 14 10;">

        <!-- Tableau de bord (commun) -->
        <Button fx:id="btnDashboard"
                text="  Tableau de bord"
                onAction="#showDashboard"
                styleClass="nav-btn"/>

        <!-- ── SECTION ADMIN (masquée pour parent) ── -->
        <Label text="ADMIN" styleClass="sidebar-section-label" fx:id="sectionAdmin"/>

        <Button fx:id="btnUsers"
                text="  Utilisateurs"
                onAction="#showUsers"
                styleClass="nav-btn"/>

        <Button fx:id="btnTeachers"
                text="  Enseignants"
                onAction="#showTeachers"
                styleClass="nav-btn"/>

        <Button fx:id="btnParents"
                text="  Parents"
                onAction="#showParents"
                styleClass="nav-btn"/>

        <Button fx:id="btnEventList"
                text="  Liste des événements"
                onAction="#showEventList"
                styleClass="nav-btn"/>

        <Button fx:id="btnRegistrationList"
                text="  Inscriptions"
                onAction="#showRegistrationList"
                styleClass="nav-btn"/>

        <!-- ── SECTION ENSEIGNANT (masquée pour parent) ── -->
        <Label text="COURS" styleClass="sidebar-section-label" fx:id="sectionTeacher"/>

        <Button fx:id="btnCourses"
                text="  Mes cours"
                onAction="#showCourses"
                styleClass="nav-btn"/>

        <Button fx:id="btnStudents"
                text="  Mes élèves"
                onAction="#showStudents"
                styleClass="nav-btn"/>

        <!-- ── SECTION PARENT (visible pour parent) ── -->
        <Label text="ÉVÉNEMENTS" styleClass="sidebar-section-label" fx:id="sectionEvents"/>

        <Button fx:id="btnParentEventList"
                text="  Événements"
                onAction="#showParentEventList"
                styleClass="nav-btn"/>

        <Button fx:id="btnParentRegistrations"
                text="  Mes inscriptions"
                onAction="#showParentRegistrations"
                styleClass="nav-btn"/>

        <Label text="FAMILLE" styleClass="sidebar-section-label" fx:id="sectionFamily"/>

        <Button fx:id="btnChildren"
                text="  Mes enfants"
                onAction="#showChildren"
                styleClass="nav-btn"/>

        <!-- Profil (commun) -->
        <VBox style="-fx-padding: 8 0 0 0;
                     -fx-border-color: #2A2A4E; -fx-border-width: 1 0 0 0;">
            <Button fx:id="btnProfile"
                    text="  Mon profil"
                    onAction="#showProfile"
                    styleClass="nav-btn"/>
        </VBox>

    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <VBox style="-fx-padding: 14 16;
                 -fx-border-color: #2A2A4E; -fx-border-width: 1 0 0 0;"
          spacing="10">

        <HBox spacing="10" alignment="CENTER_LEFT">
            <VBox alignment="CENTER"
                  style="-fx-background-color: -ep-accent;
                         -fx-background-radius: 50;
                         -fx-min-width: 36; -fx-min-height: 36;
                         -fx-max-width: 36; -fx-max-height: 36;">
                <Label fx:id="labelUserInitials"
                       text="U"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
            </VBox>
            <VBox spacing="1">
                <Label fx:id="labelUserName"  text="" styleClass="sidebar-user-name"/>
                <Label fx:id="labelUserRole"  text="" styleClass="sidebar-user-role"/>
            </VBox>
        </HBox>

        <Button text="  Déconnexion"
                onAction="#handleLogout"
                styleClass="sidebar-logout-btn"/>
    </VBox>

</VBox>