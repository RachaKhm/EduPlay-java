<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dev.eduplay.controllers.LoginController"
           stylesheets="@../../styles/auth.css"
           styleClass="auth-stack-pane">

    <!-- ===== VUE PRINCIPALE (Login normal) ===== -->
    <HBox fx:id="loginBox">

        <!-- Panneau gauche branding -->
        <VBox alignment="CENTER" prefWidth="420"
              styleClass="auth-branding-panel">
            <VBox spacing="20" alignment="CENTER">
                <Label text="EduPlay"
                       styleClass="auth-logo-text"/>
                <Label text="Plateforme éducative"
                       styleClass="auth-subtitle"/>
                <VBox spacing="0" styleClass="auth-feature-list">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="●" styleClass="auth-feature-dot"/>
                        <Label text="Gestion multi-rôles"
                               styleClass="auth-feature-text"/>
                    </HBox>
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 0;">
                        <Label text="●" styleClass="auth-feature-dot"/>
                        <Label text="Suivi des apprentissages"
                               styleClass="auth-feature-text"/>
                    </HBox>
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 0;">
                        <Label text="●" styleClass="auth-feature-dot"/>
                        <Label text="Communication parent-enseignant"
                               styleClass="auth-feature-text"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>

        <!-- Panneau droit formulaire -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              styleClass="auth-form-panel">

            <VBox spacing="0" maxWidth="360">

                <Label text="Connexion"
                       styleClass="auth-form-title"/>
                <Label text="Accédez à votre espace EduPlay"
                       styleClass="auth-form-subtitle"/>

                <!-- Email / Username -->
                <Label text="Email ou identifiant"
                       styleClass="auth-label"/>
                <TextField fx:id="emailField"
                           promptText="votre@email.com ou identifiant"
                           styleClass="auth-input"/>

                <!-- Mot de passe -->
                <Label text="Mot de passe"
                       styleClass="auth-label" style="-fx-padding: 14 0 0 0;"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               onAction="#handleLogin"
                               styleClass="auth-input"/>

                <!-- Message erreur/succès -->
                <Label fx:id="errorLabel" text="" wrapText="true"
                       styleClass="auth-error-label"/>

                <!-- Bouton connexion -->
                <Button text="Se connecter"
                        onAction="#handleLogin"
                        maxWidth="Infinity"
                        styleClass="auth-primary-button">
                    <VBox.margin><Insets top="16"/></VBox.margin>
                </Button>

                <!-- Séparateur OU -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 16 0;">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="OU" style="-fx-text-fill: #BBBBCC; -fx-font-size: 11px;"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Bouton Webcam (reconnaissance faciale) -->
                <Button text="📷  Se connecter par reconnaissance faciale"
                        onAction="#goToFaceLogin"
                        maxWidth="Infinity"
                        styleClass="auth-secondary-button"/>

                <!-- Liens bas -->
                <VBox spacing="6" alignment="CENTER" style="-fx-padding: 18 0 0 0;">
                    <Label text="Vous n'avez pas de compte ?"
                           styleClass="auth-footer-link"/>
                    <Hyperlink text="Créer un compte parent"
                               onAction="#goToSignup"
                               styleClass="auth-footer-link-active"/>
                </VBox>

                <Hyperlink text="Mot de passe oublié ?"
                           onAction="#goToForgotPassword"
                           styleClass="auth-footer-link" style="-fx-padding: 4 0 0 0;"/>

                <Label text="EduPlay v1.0 — ESPRIT 2026"
                       styleClass="auth-version-text"
                       maxWidth="Infinity" alignment="CENTER"/>
            </VBox>
        </VBox>
    </HBox>

    <!-- ===== VUE OTP (superposée via StackPane) ===== -->
    <!-- Caché au départ — visible après validation du mot de passe -->
    <HBox fx:id="otpBox" visible="false" managed="false">

        <!-- Panneau gauche branding identique -->
        <VBox alignment="CENTER" prefWidth="420"
              styleClass="auth-branding-panel">
            <Label text="EduPlay"
                   styleClass="auth-logo-text"/>
            <Label text="Vérification en 2 étapes"
                   styleClass="auth-subtitle" style="-fx-padding: 8 0 0 0;"/>
        </VBox>

        <!-- Panneau droit OTP -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              styleClass="auth-form-panel">
            <VBox spacing="0" maxWidth="360">

                <Label text="Code de vérification"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
                <Label fx:id="otpInfoLabel"
                       text="Un code a été envoyé à votre email."
                       wrapText="true"
                       styleClass="auth-form-subtitle"/>

                <Label text="Code à 6 chiffres"
                       styleClass="auth-label"/>
                <TextField fx:id="otpField"
                           promptText="• • • • • •"
                           styleClass="auth-input, otp-input"/>

                <Label fx:id="otpErrorLabel" text="" wrapText="true"
                       styleClass="auth-error-label"/>

                <Button text="Vérifier le code"
                        onAction="#handleVerifyOtp"
                        maxWidth="Infinity"
                        styleClass="auth-primary-button">
                    <VBox.margin><Insets top="16"/></VBox.margin>
                </Button>

                <Hyperlink text="← Retour"
                           onAction="#backToLogin"
                           styleClass="auth-footer-link" style="-fx-padding: 12 0 0 0;"/>
            </VBox>
        </VBox>
    </HBox>

</StackPane>
