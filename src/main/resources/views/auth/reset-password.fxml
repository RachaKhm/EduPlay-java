<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dev.eduplay.controllers.ResetPasswordController"
           stylesheets="@../../styles/auth.css"
           styleClass="auth-stack-pane">

    <HBox>
        <!-- Panneau gauche branding -->
        <VBox alignment="CENTER" prefWidth="380"
              styleClass="auth-branding-panel">
            <Label text="EduPlay"
                   styleClass="auth-logo-text" style="-fx-font-size: 38px;"/>
            <Label text="Nouveau mot de passe"
                   styleClass="auth-subtitle" style="-fx-padding: 8 0 0 0;"/>
        </VBox>

        <!-- Panneau droit formulaire -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              styleClass="auth-form-panel">
            <VBox spacing="0" maxWidth="360">

                <Label text="Réinitialisation"
                       styleClass="auth-form-title" style="-fx-font-size: 24px;"/>
                <Label text="Entrez le code reçu par email et choisissez un nouveau mot de passe."
                       wrapText="true"
                       styleClass="auth-form-subtitle"/>

                <!-- Token -->
                <Label text="Code reçu par email"
                       styleClass="auth-label"/>
                <TextField fx:id="tokenField"
                           promptText="Collez le code ici"
                           styleClass="auth-input"/>
                <Label fx:id="tokenHintLabel" text=""
                       styleClass="auth-subtitle" style="-fx-font-size: 11px; -fx-padding: 2 0 0 0;"/>

                <!-- Nouveau mot de passe -->
                <Label text="Nouveau mot de passe"
                       styleClass="auth-label" style="-fx-padding: 14 0 0 0;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Min. 8 caractères"
                               styleClass="auth-input"/>

                <!-- Confirmation -->
                <Label text="Confirmer le mot de passe"
                       styleClass="auth-label" style="-fx-padding: 14 0 0 0;"/>
                <PasswordField fx:id="confirmField"
                               promptText="Répétez le mot de passe"
                               styleClass="auth-input"/>

                <Label fx:id="messageLabel" text="" wrapText="true"
                       styleClass="auth-error-label" style="-fx-padding: 10 0 0 0;"/>

                <Button fx:id="resetButton"
                        text="Réinitialiser le mot de passe"
                        onAction="#handleReset"
                        maxWidth="Infinity"
                        styleClass="auth-primary-button">
                    <VBox.margin><Insets top="20"/></VBox.margin>
                </Button>

                <Hyperlink text="Recommencer depuis le debut" onAction="#goToForgotPassword"
                           styleClass="auth-footer-link" style="-fx-padding: 12 0 0 0;"/>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
