<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.eduplay.controllers.ResetPasswordController"
      alignment="CENTER" spacing="16"
      style="-fx-padding: 40; -fx-background-color: #f5f7fa;">

    <Text text="Nouveau mot de passe 🔒" style="-fx-font-size: 22; -fx-font-weight: bold;"/>

    <TextField fx:id="tokenField" promptText="Code reçu par email"
               maxWidth="320" styleClass="input-field"/>

    <PasswordField fx:id="passwordField" promptText="Nouveau mot de passe"
                   maxWidth="320" styleClass="input-field"/>

    <PasswordField fx:id="confirmField" promptText="Confirmer le mot de passe"
                   maxWidth="320" styleClass="input-field"/>

    <Label fx:id="messageLabel" style="-fx-text-fill: red;"/>

    <Button text="Réinitialiser" onAction="#handleReset"
            maxWidth="320" styleClass="btn-primary"/>
</VBox>