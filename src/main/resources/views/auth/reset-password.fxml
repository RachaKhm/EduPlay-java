<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="dev.eduplay.controllers.ResetPasswordController"
           style="-fx-background-color: linear-gradient(to bottom right, #f8faff, #eef2f7);">

    <VBox alignment="CENTER" spacing="30" maxWidth="450" maxHeight="500"
          style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 30, 0, 0, 15); -fx-padding: 50;">
        
        <VBox alignment="CENTER" spacing="10">
            <Label text="Réinitialisation" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #1a1c1e;"/>
            <Label text="Sécurisez votre compte avec un nouveau mot de passe" 
                   style="-fx-font-size: 14px; -fx-text-fill: #64748b;" wrapText="true" textAlignment="CENTER"/>
        </VBox>

        <VBox spacing="18">
            <VBox spacing="6">
                <Label text="Nouveau mot de passe" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: transparent; -fx-font-size: 14px;"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Confirmer le mot de passe" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="confirmField" promptText="••••••••"
                               style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-padding: 14; -fx-border-color: transparent; -fx-font-size: 14px;"/>
            </VBox>
        </VBox>

        <VBox alignment="CENTER" spacing="12">
            <Label fx:id="messageLabel" style="-fx-font-size: 13px; -fx-text-fill: #e11d48;" wrapText="true" textAlignment="CENTER"/>
            
            <Button fx:id="resetBtn" text="Changer le mot de passe" onAction="#handleReset"
                    maxWidth="Infinity"
                    style="-fx-background-color: #4A90E2; -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 15px; -fx-padding: 14; -fx-background-radius: 12; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(74,144,226,0.3), 10, 0, 0, 4);"/>
            
            <Hyperlink text="Retour à la connexion" onAction="#goToLogin"
                       style="-fx-text-fill: #64748b; -fx-font-size: 13px; -fx-underline: false;"/>
        </VBox>
    </VBox>

</StackPane>