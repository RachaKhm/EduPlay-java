<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.eduplay.controllers.ForgotPasswordController"
      alignment="CENTER" spacing="16"
      style="-fx-padding: 40; -fx-background-color: #f5f7fa;">

    <Text text="Mot de passe oublié 🔑" style="-fx-font-size: 22; -fx-font-weight: bold;"/>
    <Text text="Entrez votre email pour recevoir un lien de réinitialisation."
          style="-fx-fill: #666;"/>

    <TextField fx:id="emailField" promptText="Votre adresse email"
               maxWidth="320" styleClass="input-field"/>

    <Label fx:id="messageLabel" style="-fx-text-fill: red;"/>

    <Button text="Envoyer le lien" onAction="#handleSend"
            maxWidth="320" styleClass="btn-primary"/>

    <Hyperlink text="Retour à la connexion" onAction="#goToLogin"/>
</VBox>