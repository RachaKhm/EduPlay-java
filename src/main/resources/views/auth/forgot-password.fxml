<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dev.eduplay.controllers.ForgotPasswordController"
           stylesheets="@../../styles/auth.css"
           styleClass="auth-stack-pane">

    <HBox>
        <!-- Panneau gauche branding -->
        <VBox alignment="CENTER" prefWidth="380"
              styleClass="auth-branding-panel">
            <Label text="EduPlay"
                   styleClass="auth-logo-text" style="-fx-font-size: 38px;"/>
            <Label text="Récupération de compte"
                   styleClass="auth-subtitle" style="-fx-padding: 8 0 0 0;"/>
        </VBox>

        <!-- Panneau droit formulaire -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              styleClass="auth-form-panel">
            <VBox spacing="0" maxWidth="360">

                <Label text="Mot de passe oublié"
                       styleClass="auth-form-title" style="-fx-font-size: 24px;"/>
                <Label text="Entrez votre email pour recevoir un code de réinitialisation."
                       wrapText="true"
                       styleClass="auth-form-subtitle"/>

                <Label text="Adresse email"
                       styleClass="auth-label"/>
                <TextField fx:id="emailField"
                           promptText="votre@email.com"
                           styleClass="auth-input"/>

                <Label fx:id="messageLabel" text="" wrapText="true"
                       styleClass="auth-error-label" style="-fx-padding: 10 0 0 0;"/>

                <Button fx:id="sendButton"
                        text="Envoyer le code"
                        onAction="#handleSend"
                        maxWidth="Infinity"
                        styleClass="auth-primary-button">
                    <VBox.margin><Insets top="20"/></VBox.margin>
                </Button>

                <Hyperlink text="Retour à la connexion" onAction="#goToLogin"
                           styleClass="auth-footer-link" style="-fx-padding: 12 0 0 0;"/>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
