<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="dev.eduplay.controllers.ForgotPasswordController"
           style="-fx-background-color: #1A1A2E;">

    <HBox>
        <!-- Panneau gauche branding -->
        <VBox alignment="CENTER" prefWidth="380"
              style="-fx-background-color: #12122A; -fx-padding: 60;">
            <Label text="EduPlay"
                   style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
            <Label text="Récupération de compte"
                   style="-fx-font-size: 14px; -fx-text-fill: #555577; -fx-padding: 8 0 0 0;"/>
        </VBox>

        <!-- Panneau droit formulaire -->
        <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #F8F9FA; -fx-padding: 60 80;">
            <VBox spacing="0" maxWidth="360">

                <Label text="Mot de passe oublié"
                       style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
                <Label text="Entrez votre email pour recevoir un code de réinitialisation."
                       wrapText="true"
                       style="-fx-font-size: 13px; -fx-text-fill: #9999BB; -fx-padding: 6 0 28 0;"/>

                <Label text="Adresse email"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555577;"/>
                <TextField fx:id="emailField"
                           promptText="votre@email.com"
                           style="-fx-background-color: white;
                                  -fx-border-color: #DDDDE8; -fx-border-width: 1;
                                  -fx-background-radius: 8; -fx-border-radius: 8;
                                  -fx-padding: 11 14; -fx-font-size: 14px;"/>

                <Label fx:id="messageLabel" text="" wrapText="true"
                       style="-fx-font-size: 12px; -fx-padding: 10 0 0 0;"/>

                <Button fx:id="sendButton"
                        text="Envoyer le code"
                        onAction="#handleSend"
                        maxWidth="Infinity"
                        style="-fx-background-color: #E94560; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-padding: 12; -fx-background-radius: 8;
                               -fx-cursor: hand; -fx-border-width: 0;">
                    <VBox.margin><Insets top="20"/></VBox.margin>
                </Button>

                <Hyperlink text="Retour à la connexion" onAction="#goToLogin"
                           style="-fx-font-size: 12px; -fx-text-fill: #9999BB;
                                  -fx-border-width: 0; -fx-padding: 12 0 0 0;"/>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
