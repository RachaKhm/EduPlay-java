<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.SidebarController"
      prefWidth="260"
      spacing="0"
      style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 1 0 0;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-padding: 24; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">

        <StackPane>
            <Rectangle width="48" height="48" arcWidth="24" arcHeight="24">
                <fill>
                    <LinearGradient startX="0" startY="0" endX="1" endY="1">
                        <stops>
                            <Stop offset="0.0" color="#3B82F6"/>
                            <Stop offset="1.0" color="#4F46E5"/>
                        </stops>
                    </LinearGradient>
                </fill>
            </Rectangle>
            <Label text="🎓" style="-fx-text-fill: white; -fx-font-size: 24px;"/>
        </StackPane>

        <VBox spacing="2">
            <HBox>
                <Label text="Edu" style="-fx-font-weight: bold; -fx-font-size: 20px;"/>
                <Label text="Play" style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #2563EB;"/>
            </HBox>
            <Label text="Super Admin" style="-fx-text-fill: #6B7280; -fx-font-size: 13px;"/>
        </VBox>

    </HBox>

    <!-- NAV -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;">

        <VBox spacing="6" style="-fx-padding: 16;">

            <!-- DASHBOARD -->
            <HBox fx:id="btnDashboard"
                  onMouseClicked="#showDashboard"
                  alignment="CENTER_LEFT"
                  spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox alignment="CENTER_LEFT">
                    <Label text="📊 Dashboard"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- ADMIN SECTION -->
            <HBox fx:id="sectionAdminBox" spacing="8"
                  style="-fx-padding: 20 0 5 0;">
                <Label fx:id="sectionAdmin"
                       text="ADMIN"
                       style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-weight: bold;"/>
            </HBox>

            <!-- USERS -->
            <HBox fx:id="btnUsers"
                  onMouseClicked="#showUsers"
                  alignment="CENTER_LEFT"
                  spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox alignment="CENTER_LEFT">
                    <Label text="👥 Utilisateurs"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- LIBRARY -->
            <HBox fx:id="btnLibrary"
                  onMouseClicked="#showLibrary"
                  alignment="CENTER_LEFT"
                  spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox alignment="CENTER_LEFT">
                    <Label text="📚 Bibliothèque"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- RESOURCES -->
            <HBox fx:id="btnResource"
                  onMouseClicked="#showResource"
                  alignment="CENTER_LEFT"
                  spacing="12"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox alignment="CENTER_LEFT">
                    <Label text="📂 Ressources"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- TEACHER -->
            <HBox fx:id="sectionTeacherBox" style="-fx-padding: 20 0 5 0;">
                <Label fx:id="sectionTeacher"
                       text="COURS"
                       style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-weight: bold;"/>
            </HBox>

            <HBox fx:id="btnCourses"
                  onMouseClicked="#showCourses"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox>
                    <Label text="📖 Mes cours"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <HBox fx:id="btnStudents"
                  onMouseClicked="#showStudents"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox>
                    <Label text="🎓 Mes élèves"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- PARENT -->
            <HBox fx:id="sectionParentBox" style="-fx-padding: 20 0 5 0;">
                <Label fx:id="sectionParent"
                       text="FAMILLE"
                       style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-weight: bold;"/>
            </HBox>

            <HBox fx:id="btnChildren"
                  onMouseClicked="#showChildren"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox>
                    <Label text="👨‍👧‍👦 Enfants"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <HBox fx:id="btnEvents"
                  onMouseClicked="#showEvents"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox>
                    <Label text="📅 Événements"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- CHILD -->
            <HBox fx:id="sectionChildBox" style="-fx-padding: 20 0 5 0;">
                <Label fx:id="sectionChild"
                       text="APPRENTISSAGE"
                       style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-weight: bold;"/>
            </HBox>

            <HBox fx:id="btnMyCoursesChild"
                  onMouseClicked="#showMyCoursesChild"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox>
                    <Label text="📖 Mes cours"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <HBox fx:id="btnGames"
                  onMouseClicked="#showGames"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox>
                    <Label text="🎮 Jeux"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <HBox fx:id="btnChildLibrary"
                  onMouseClicked="#showChildLibrary"
                  style="-fx-background-color: linear-gradient(to right, #667EEA, #764BA2);
                         -fx-padding: 6 16 6 6;
                         -fx-background-radius: 24;
                         -fx-cursor: hand;"
                  styleClass="modern-nav-btn">

                <VBox>
                    <Label text="📚 Bibliothèque"
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>

    <!-- Footer logout -->
    <VBox style="-fx-padding: 16; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0;">
        <Button onAction="#handleLogout" styleClass="modern-logout-btn"
                style="-fx-background-color: #FEF2F2; -fx-border-width: 0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 8 12; -fx-cursor: hand; -fx-pref-width: 250;">
            <graphic>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane>
                        <Rectangle width="32" height="32" arcWidth="16" arcHeight="16">
                            <fill>
                                <LinearGradient startX="0" startY="0" endX="1" endY="1">
                                    <stops>
                                        <Stop offset="0.0" color="#EF4444"/>
                                        <Stop offset="1.0" color="#E11D48"/>
                                    </stops>
                                </LinearGradient>
                            </fill>
                        </Rectangle>
                        <Label text="➔" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <Label text="Déconnexion" style="-fx-text-fill: #DC2626; -fx-font-weight: bold;"/>
                        <Label fx:id="labelUserName" text="Utilisateur" style="-fx-text-fill: #6B7280; -fx-font-size: 11px;"/>
                    </VBox>
                </HBox>
            </graphic>
        </Button>
        <!-- Hidden initial labels for compatibility with old controller -->
        <Label fx:id="labelUserRole" visible="false" managed="false"/>
        <Label fx:id="labelUserInitials" visible="false" managed="false"/>
    </VBox>

</VBox>