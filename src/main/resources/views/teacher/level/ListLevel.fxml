<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.LevelController"
            prefWidth="900"
            style="-fx-background-color: #F8F9FA;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1A1A2E; -fx-padding: 18 24;">
            <VBox spacing="3">
                <Label text="Gestion des niveaux"
                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Liste des niveaux éducatifs — EduPlay"
                       style="-fx-font-size: 11px; -fx-text-fill: #555577;"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 28 24 28;">
            <!-- Statistiques avec dégradés JavaFX compatible -->
            <HBox spacing="15" alignment="CENTER">
                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #667eea, #764ba2);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="📚" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statTotalLevels" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Total niveaux"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #2E9E6E, #1B5E3F);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="🟢" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statEasyLevels" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Niveaux faciles"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #F39C12, #E67E22);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="🟡" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statMediumLevels" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Niveaux moyens"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #E94560, #C0392B);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="🔴" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statHardLevels" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Niveaux difficiles"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>
            </HBox>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button onAction="#Page_Ajout" style="-fx-background-color: #E94560; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6;-fx-cursor: hand;">
                    + Nouveau niveau
                </Button>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Rechercher un niveau..."
                           style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                  -fx-border-width: 1; -fx-background-radius: 20;
                                  -fx-border-radius: 20; -fx-padding: 6 12; -fx-font-size: 13px;
                                  -fx-pref-width: 200;"/>
            </HBox>

            <TableView fx:id="levelTable">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colName" text="Nom" prefWidth="180"/>
                    <TableColumn fx:id="colDifficulty" text="Difficulté" prefWidth="100"/>
                    <TableColumn fx:id="colAgeRange" text="Tranche d'âge" prefWidth="120"/>
                    <TableColumn fx:id="colPedagGoal" text="Objectif pédagogique" prefWidth="250"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="250"/>
                </columns>
                <placeholder>
                    <Label text="Aucun niveau trouvé" style="-fx-text-fill: #9999BB; -fx-padding: 40;"/>
                </placeholder>
            </TableView>

            <Label fx:id="statusLabel" text="0 niveau(x)" style="-fx-text-fill: #777799; -fx-font-size: 12px;"/>

        </VBox>
    </center>

</BorderPane>