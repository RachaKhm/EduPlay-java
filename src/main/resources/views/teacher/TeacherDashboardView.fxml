<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.TeacherDashboardController"
      spacing="0" style="-fx-background-color: #F8F9FA;">
    <HBox style="-fx-padding: 0 0 24 0;">
        <VBox spacing="4">
            <Label text="Espace Enseignant"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #22223A;"/>
            <Label fx:id="subtitleLabel" text=""
                   style="-fx-font-size: 13px; -fx-text-fill: #9999BB;"/>
        </VBox>
    </HBox>
    <HBox spacing="16">
        <VBox spacing="6" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFF5F7; -fx-padding: 20;
                     -fx-background-radius: 10; -fx-border-color: #F8C8D0;
                     -fx-border-width: 1; -fx-border-radius: 10;">
            <Label text="Mes cours" style="-fx-font-size: 12px; -fx-text-fill: #C0607A;"/>
            <Label fx:id="totalCoursesLabel" text="—"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #E94560;"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #F0F5FF; -fx-padding: 20;
                     -fx-background-radius: 10; -fx-border-color: #C0D0F8;
                     -fx-border-width: 1; -fx-border-radius: 10;">
            <Label text="Mes élèves" style="-fx-font-size: 12px; -fx-text-fill: #4060C0;"/>
            <Label fx:id="totalStudentsLabel" text="—"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4A90D9;"/>
        </VBox>
    </HBox>
</VBox>
