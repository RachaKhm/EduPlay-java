<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.GameController"
            prefWidth="900"
            style="-fx-background-color: #F8F9FA;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1A1A2E; -fx-padding: 18 24;">
            <VBox spacing="3">
                <Label text="Gestion des jeux"
                       style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Liste des jeux éducatifs — EduPlay"
                       style="-fx-font-size: 11px; -fx-text-fill: #555577;"/>
            </VBox>
            <HBox HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24 28 24 28;">

            <!-- Statistiques -->
            <HBox spacing="15" alignment="CENTER">
                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #667eea, #764ba2);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="🎮" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statTotalGames" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Total jeux"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #2E9E6E, #1B5E3F);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="📖" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statQuizGames" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Jeux Quiz"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #F39C12, #E67E22);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="🧩" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statPuzzleGames" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Jeux Puzzle"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15"
                      style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #E94560, #C0392B);
                             -fx-background-radius: 12; -fx-padding: 15 20; -fx-pref-width: 200;">
                    <Label text="🏆" style="-fx-font-size: 28px; -fx-text-fill: white;"/>
                    <VBox>
                        <Label fx:id="statOtherGames" text="0"
                               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Autres jeux"
                               style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- Barre d'outils -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button onAction="#Page_Ajout" style="-fx-background-color: #E94560; -fx-text-fill: white;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;">
                    + Nouveau jeu
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="searchField" promptText="Rechercher un jeu..."
                           style="-fx-background-color: white; -fx-border-color: #DDDDE8;
                                  -fx-border-width: 1; -fx-background-radius: 20;
                                  -fx-border-radius: 20; -fx-padding: 6 12; -fx-font-size: 13px;
                                  -fx-pref-width: 200;"/>
            </HBox>






            <!-- Tableau des jeux -->
            <TableView fx:id="gameTable">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colName" text="Nom" prefWidth="180"/>
                    <TableColumn fx:id="colLevel" text="Niveau" prefWidth="120"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="280"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
                </columns>
                <placeholder>
                    <Label text="Aucun jeu trouvé" style="-fx-text-fill: #9999BB; -fx-padding: 40;"/>
                </placeholder>
            </TableView>

            <Label fx:id="statusLabel" text="0 jeu(x)" style="-fx-text-fill: #777799; -fx-font-size: 12px;"/>

        </VBox>
    </center>

</BorderPane>