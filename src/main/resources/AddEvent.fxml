<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="800.0" stylesheets="@/css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.eduplay.controllers.AddEventController">

    <children>
        <ScrollPane layoutX="30.0" layoutY="20.0" prefWidth="740.0" prefHeight="700.0" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="25" styleClass="card">
                    <padding>
                        <Insets top="30" right="30" bottom="30" left="30"/>
                    </padding>

                    <children>
                        <!-- En-tête avec icône -->
                        <VBox spacing="8">
                            <Label text="✨ Créer un événement" styleClass="title-label"/>
                            <Label text="Remplissez le formulaire ci-dessous pour créer un nouvel événement" styleClass="subtitle-label"/>
                            <Separator>
                                <padding>
                                    <Insets top="5" bottom="5"/>
                                </padding>
                            </Separator>
                        </VBox>

                        <!-- Formulaire -->
                        <GridPane hgap="20" vgap="18">
                            <padding>
                                <Insets top="5"/>
                            </padding>

                            <columnConstraints>
                                <ColumnConstraints hgrow="NEVER" minWidth="130.0" prefWidth="130.0"/>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="450.0" prefWidth="480.0"/>
                            </columnConstraints>

                            <children>
                                <!-- Titre -->
                                <Label text="Titre" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label"/>
                                <TextField fx:id="titleField" promptText="Ex: Petits Mosaïstes" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <!-- Description -->
                                <Label text="Description" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label"/>
                                <TextArea fx:id="descriptionArea" promptText="Description détaillée de l'événement..." prefHeight="100" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <!-- Date de début -->
                                <Label text="Date de début" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label"/>
                                <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="2" alignment="CENTER_LEFT">
                                    <DatePicker fx:id="startDatePicker" promptText="AAAA-MM-JJ" prefWidth="180"/>
                                    <Label text="à" style="-fx-padding: 0 5 0 5; -fx-text-fill: #6c757d;"/>
                                    <ComboBox fx:id="startHourCombo" prefWidth="80" promptText="HH"/>
                                    <Label text=":" style="-fx-padding: 0 0 0 0; -fx-text-fill: #6c757d;"/>
                                    <ComboBox fx:id="startMinuteCombo" prefWidth="80" promptText="MM"/>
                                </HBox>

                                <!-- Date de fin -->
                                <Label text="Date de fin" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="field-label"/>
                                <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3" alignment="CENTER_LEFT">
                                    <DatePicker fx:id="endDatePicker" promptText="AAAA-MM-JJ" prefWidth="180"/>
                                    <Label text="à" style="-fx-padding: 0 5 0 5; -fx-text-fill: #6c757d;"/>
                                    <ComboBox fx:id="endHourCombo" prefWidth="80" promptText="HH"/>
                                    <Label text=":" style="-fx-padding: 0 0 0 0; -fx-text-fill: #6c757d;"/>
                                    <ComboBox fx:id="endMinuteCombo" prefWidth="80" promptText="MM"/>
                                </HBox>

                                <!-- Lieu -->
                                <Label text="Lieu" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label"/>
                                <TextField fx:id="locationField" promptText="Ex: musée de bardo tunis" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                <!-- Image -->
                                <Label text="Image" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="field-label"/>
                                <HBox spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="5" alignment="CENTER_LEFT">
                                    <TextField fx:id="imagePathField" promptText="Aucun fichier sélectionné" prefWidth="350" editable="false"/>
                                    <Button fx:id="browseImageBtn" text="📁 Parcourir" styleClass="btn-browse"/>
                                </HBox>

                                <!-- Aperçu -->
                                <Label text="Aperçu" GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="field-label"/>
                                <StackPane fx:id="imagePreviewPane" GridPane.columnIndex="1" GridPane.rowIndex="6" prefHeight="130.0" prefWidth="220.0" styleClass="image-preview">
                                    <Label text="🖼️ Aucune image" fx:id="noImageLabel" style="-fx-text-fill: #adb5bd; -fx-font-size: 13px;"/>
                                </StackPane>
                            </children>
                        </GridPane>

                        <Separator/>

                        <!-- Message -->
                        <Label fx:id="messageLabel" wrapText="true"/>

                        <!-- Boutons -->
                        <HBox spacing="15" alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="cancelBtn" text="Annuler" styleClass="btn-secondary"/>
                                <Button fx:id="submitBtn" text="✅ Créer l'événement" styleClass="btn-primary"/>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>