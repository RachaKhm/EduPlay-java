<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.AddEventController"
            style="-fx-background-color: #f3f4f6; -fx-background: #f3f4f6;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #f3f4f6;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <!-- En-tête -->
                <Label text="Créer un événement" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Remplis le formulaire pour ajouter un nouvel événement." style="-fx-text-fill: #64748b; -fx-font-size: 14px; -fx-padding: 0 0 10 0;"/>

                <!-- Carte formulaire -->
                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25"/>
                    </padding>

                    <children>
                        <!-- Titre -->
                        <VBox spacing="5">
                            <Label text="Titre" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <TextField fx:id="titleField" promptText="Ex: Sortie au musée" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-background-color: white; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Date début -->
                        <VBox spacing="5">
                            <Label text="Date début" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <DatePicker fx:id="startDatePicker" promptText="jj/mm/aaaa" prefWidth="180" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <ComboBox fx:id="startHourCombo" prefWidth="80" promptText="HH" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <Label text=":" style="-fx-padding: 0;"/>
                                <ComboBox fx:id="startMinuteCombo" prefWidth="80" promptText="MM" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                            </HBox>
                        </VBox>

                        <!-- Date fin -->
                        <VBox spacing="5">
                            <Label text="Date fin" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <DatePicker fx:id="endDatePicker" promptText="jj/mm/aaaa" prefWidth="180" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <ComboBox fx:id="endHourCombo" prefWidth="80" promptText="HH" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                                <Label text=":" style="-fx-padding: 0;"/>
                                <ComboBox fx:id="endMinuteCombo" prefWidth="80" promptText="MM" style="-fx-padding: 8; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0;"/>
                            </HBox>
                        </VBox>

                        <!-- Lieu -->
                        <VBox spacing="5">
                            <Label text="Lieu" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <TextField fx:id="locationField" promptText="Ex: Musée du Bardo, Tunis" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-background-color: white; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Description -->
                        <VBox spacing="5">
                            <Label text="Description" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <TextArea fx:id="descriptionArea" promptText="Décris l'événement..." prefHeight="100" wrapText="true" style="-fx-padding: 12; -fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #e2e8f0; -fx-background-color: white; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- Image -->
                        <VBox spacing="5">
                            <Label text="Image" style="-fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Button fx:id="browseImageBtn" text="Choisir un fichier" style="-fx-background-color: #e2e8f0; -fx-text-fill: #1e293b; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                                <Label fx:id="fileNameLabel" text="Aucun fichier n'a été sélectionné" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>
                            </HBox>
                        </VBox>

                        <!-- Message d'erreur/succès -->
                        <Label fx:id="messageLabel" wrapText="true" style="-fx-font-size: 13px;"/>

                        <!-- Aperçu image -->
                        <StackPane fx:id="imagePreviewPane" prefHeight="150" prefWidth="250" style="-fx-background-color: #f8fafc; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-border-style: dashed;" visible="false" managed="false">
                            <Label text="🖼️ Aperçu de l'image" style="-fx-text-fill: #94a3b8;"/>
                        </StackPane>

                        <!-- Boutons -->
                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                            <Button fx:id="cancelBtn" text="Annuler" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 14px;"/>
                            <Button fx:id="submitBtn" text="Enregistrer" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px; -fx-effect: dropshadow(gaussian, rgba(245,158,11,0.3), 5, 0, 0, 2);"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>