<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.ProductIndexController" spacing="12" style="-fx-padding:16;">

    <HBox spacing="8">
        <Label text="Produits" style="-fx-font-size:18px;-fx-font-weight:bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕ Ajouter" onAction="#addProduct" />
    </HBox>

    <HBox spacing="8">
        <TextField fx:id="txtSearchName" promptText="Rechercher par nom..." />
        <Label fx:id="lblProductCount" text="0 résultats" />
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="gridProducts" hgap="12" vgap="12" prefWrapLength="900" />
    </ScrollPane>

</VBox>

