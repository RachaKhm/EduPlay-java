<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<ScrollPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.eduplay.controllers.ResourceDetailController"
            style="-fx-background-color: #f3f4f6; -fx-background: #f3f4f6;"
            fitToWidth="true" fitToHeight="false">

    <content>
        <VBox spacing="20" style="-fx-background-color: #f3f4f6;" alignment="TOP_CENTER">

            <padding>
                <Insets top="25" right="35" bottom="25" left="35"/>
            </padding>

            <children>
                <!-- En-tête -->
                <VBox spacing="0" style="-fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #8b5cf6, #6d28d9); -fx-background-radius: 16 16 0 0; -fx-padding: 20 25;">
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="📄 Détails de la ressource" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;">
                                <font><Font name="System Bold" size="24"/></font>
                            </Label>
                            <Label fx:id="eventInfoLabel" text="Événement associé" style="-fx-text-fill: #ddd6fe; -fx-font-size: 13px; -fx-padding: 5 0 0 0;"/>
                        </VBox>
                        <Button fx:id="backBtn" text="← Retour à la liste" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 12; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <!-- Carte des détails -->
                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 2);">
                    <padding>
                        <Insets top="25" right="25" bottom="25" left="25"/>
                    </padding>

                    <children>
                        <!-- Titre -->
                        <VBox spacing="5">
                            <Label text="📌 Titre" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                            <Label fx:id="titleValue" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-wrap-text: true;"/>
                        </VBox>

                        <Separator/>

                        <!-- Type -->
                        <VBox spacing="5">
                            <Label text="📂 Type" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                            <Label fx:id="typeValue" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;">
                                <font><Font name="System Bold" size="14"/></font>
                            </Label>
                        </VBox>

                        <Separator/>

                        <!-- Date de création -->
                        <VBox spacing="5">
                            <Label text="📅 Date de création" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                            <Label fx:id="createdAtValue" style="-fx-font-size: 14px; -fx-text-fill: #1e293b;"/>
                        </VBox>

                        <Separator/>

                        <!-- Contexte / Description -->
                        <VBox spacing="5">
                            <Label text="📝 Contexte / Description" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                            <TextArea fx:id="contextValue" editable="false" wrapText="true" prefHeight="120" style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-padding: 12; -fx-font-size: 14px;"/>
                        </VBox>

                        <!-- URL (si disponible) -->
                        <VBox fx:id="urlBox" spacing="5" visible="false" managed="false">
                            <Label text="🔗 URL" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label fx:id="urlValue" style="-fx-text-fill: #3b82f6; -fx-font-size: 14px; -fx-cursor: hand;" wrapText="true"/>
                                <Button fx:id="openUrlBtn" text="🌐 Ouvrir" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 6 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                        <!-- Chemin du fichier (si disponible) -->
                        <VBox fx:id="filePathBox" spacing="5" visible="false" managed="false">
                            <Label text="📁 Fichier" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label fx:id="filePathValue" style="-fx-text-fill: #1e293b; -fx-font-size: 14px;" wrapText="true"/>
                                <Button fx:id="openFileBtn" text="📂 Ouvrir" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-padding: 6 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                        <!-- Boutons d'action -->
                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
                            <Button fx:id="editBtn" text="✏️ Modifier" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                            <Button fx:id="deleteBtn" text="🗑️ Supprimer" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-padding: 10 25; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>