<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.eduplay.controllers.EventResourceController"
      spacing="20" alignment="CENTER">

    <padding>
        <Insets top="50" right="50" bottom="50" left="50"/>
    </padding>

    <Label fx:id="eventTitleLabel" text="Ressources" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Button fx:id="backBtn" text="Retour" />
    <Button fx:id="addResourceBtn" text="Ajouter une ressource" />

</VBox>