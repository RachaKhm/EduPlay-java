<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.eduplay.controllers.BookFormController"
      style="-fx-background-color: #f1f5f9;" spacing="0">

    <!-- HEADER -->
    <HBox style="-fx-background-color: linear-gradient(to right,#6366f1,#9333ea);
                 -fx-padding: 28 32;" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label fx:id="headerTitle" text="📄 Nouvelle ressource"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="headerSubtitle" text="Créez une nouvelle ressource pour votre collection"
                   style="-fx-font-size: 13px; -fx-text-fill: #c7d2fe;"/>
        </VBox>
        <Button text="←  Retour" onAction="#handleRetour"
                style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 13px; -fx-background-radius: 12;
                       -fx-padding: 10 18; -fx-border-color: rgba(255,255,255,0.4);
                       -fx-border-width: 1; -fx-border-radius: 12; -fx-cursor: hand;"/>
    </HBox>

    <!-- FLASH -->
    <HBox fx:id="flashBox" alignment="CENTER_LEFT" spacing="10"
          style="-fx-padding: 10 32;" managed="false" visible="false">
        <Label fx:id="flashLabel" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: #f1f5f9;">
        <VBox style="-fx-padding: 28 32;" spacing="20">
            <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                         -fx-border-radius: 16; -fx-border-color: #e2e8f0; -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),12,0,4,0);
                         -fx-padding: 28;" spacing="20">

                <!-- Section header -->
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <HBox style="-fx-background-color: #eef2ff; -fx-background-radius: 12; -fx-padding: 10;"
                          alignment="CENTER">
                        <Label text="📝" style="-fx-font-size: 22px;"/>
                    </HBox>
                    <VBox spacing="2">
                        <Label text="Informations de la ressource"
                               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Label text="Les champs marqués * sont obligatoires"
                               style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;"/>
                    </VBox>
                </HBox>
                <Separator/>

                <!-- Titre -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Titre de la ressource"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Requis" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                               -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 2 8;"/>
                    </HBox>
                    <TextField fx:id="titleField" promptText="Ex: Le Petit Prince"
                               style="-fx-background-radius: 12; -fx-border-radius: 12;
                                      -fx-border-color: #e2e8f0; -fx-border-width: 2;
                                      -fx-padding: 11 14; -fx-font-size: 14px;"/>
                    <Label fx:id="titleError" visible="false" managed="false"
                           style="-fx-text-fill: #ef4444; -fx-font-size: 12px;
                                  -fx-background-color: #fef2f2; -fx-background-radius: 8; -fx-padding: 4 10;"/>
                    <Label text="3 à 100 caractères"
                           style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>

                <!-- Auteur -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Auteur"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Requis" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                               -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 2 8;"/>
                    </HBox>
                    <TextField fx:id="authorField" promptText="Ex: Antoine de Saint-Exupery"
                               style="-fx-background-radius: 12; -fx-border-radius: 12;
                                      -fx-border-color: #e2e8f0; -fx-border-width: 2;
                                      -fx-padding: 11 14; -fx-font-size: 14px;"/>
                    <Label fx:id="authorError" visible="false" managed="false"
                           style="-fx-text-fill: #ef4444; -fx-font-size: 12px;
                                  -fx-background-color: #fef2f2; -fx-background-radius: 8; -fx-padding: 4 10;"/>
                </VBox>

                <!-- Résumé -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Résumé"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Optionnel"
                               style="-fx-background-color: #f8fafc; -fx-text-fill: #94a3b8;
                                      -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 2 8;
                                      -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 6;"/>
                    </HBox>
                    <TextArea fx:id="summaryField" prefRowCount="3"
                              promptText="Résumez brièvement le contenu..."
                              style="-fx-background-radius: 12; -fx-border-radius: 12;
                                     -fx-border-color: #e2e8f0; -fx-border-width: 2;
                                     -fx-padding: 10 14; -fx-font-size: 14px;"/>
                    <Label text="Max 500 caractères"
                           style="-fx-font-size: 11px; -fx-text-fill: #94a3b8;"/>
                </VBox>

                <!-- Type + Langue -->
                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Type de ressource"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <Label text="Requis" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                                   -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 2 8;"/>
                        </HBox>
                        <ComboBox fx:id="typeCombo" promptText="Sélectionner..." maxWidth="Infinity"
                                  style="-fx-background-radius: 12; -fx-font-size: 14px; -fx-padding: 6 10;"/>
                        <Label fx:id="typeError" visible="false" managed="false"
                               style="-fx-text-fill: #ef4444; -fx-font-size: 12px;
                                      -fx-background-color: #fef2f2; -fx-background-radius: 8; -fx-padding: 4 10;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Langue"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <Label text="Requis" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                                   -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 2 8;"/>
                        </HBox>
                        <ComboBox fx:id="languageCombo" promptText="Sélectionner..." maxWidth="Infinity"
                                  style="-fx-background-radius: 12; -fx-font-size: 14px; -fx-padding: 6 10;"/>
                        <Label fx:id="languageError" visible="false" managed="false"
                               style="-fx-text-fill: #ef4444; -fx-font-size: 12px;
                                      -fx-background-color: #fef2f2; -fx-background-radius: 8; -fx-padding: 4 10;"/>
                    </VBox>
                </HBox>

                <!-- Âge Min + Max -->
                <HBox spacing="20">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Âge minimum"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <Label text="Requis" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                                   -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 2 8;"/>
                        </HBox>
                        <TextField fx:id="minAgeField" promptText="Ex: 3"
                                   style="-fx-background-radius: 12; -fx-border-radius: 12;
                                          -fx-border-color: #e2e8f0; -fx-border-width: 2;
                                          -fx-padding: 11 14; -fx-font-size: 14px;"/>
                        <Label fx:id="minAgeError" visible="false" managed="false"
                               style="-fx-text-fill: #ef4444; -fx-font-size: 12px;
                                      -fx-background-color: #fef2f2; -fx-background-radius: 8; -fx-padding: 4 10;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label text="Âge maximum"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                            <Label text="Requis" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                                   -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 2 8;"/>
                        </HBox>
                        <TextField fx:id="maxAgeField" promptText="Ex: 12"
                                   style="-fx-background-radius: 12; -fx-border-radius: 12;
                                          -fx-border-color: #e2e8f0; -fx-border-width: 2;
                                          -fx-padding: 11 14; -fx-font-size: 14px;"/>
                        <Label fx:id="maxAgeError" visible="false" managed="false"
                               style="-fx-text-fill: #ef4444; -fx-font-size: 12px;
                                      -fx-background-color: #fef2f2; -fx-background-radius: 8; -fx-padding: 4 10;"/>
                    </VBox>
                </HBox>

                <!-- Bibliothèque associée -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Bibliothèque associée"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Requis" style="-fx-background-color: #fef2f2; -fx-text-fill: #ef4444;
                               -fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 2 8;"/>
                    </HBox>
                    <ComboBox fx:id="libraryCombo" promptText="Sélectionner la bibliothèque parente..."
                              maxWidth="Infinity"
                              style="-fx-background-radius: 12; -fx-font-size: 14px; -fx-padding: 6 10;"/>
                    <Label fx:id="libraryError" visible="false" managed="false"
                           style="-fx-text-fill: #ef4444; -fx-font-size: 12px;
                                  -fx-background-color: #fef2f2; -fx-background-radius: 8; -fx-padding: 4 10;"/>
                </VBox>

                <!-- Image de couverture -->
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Image de couverture"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Optionnel"
                               style="-fx-background-color: #f8fafc; -fx-text-fill: #94a3b8;
                                      -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 2 8;
                                      -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 6;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="coverImageField"
                                   promptText="Cliquez sur Parcourir..." editable="false"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 12; -fx-border-radius: 12;
                                          -fx-border-color: #e2e8f0; -fx-border-width: 2;
                                          -fx-padding: 11 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                        <Button text="📁  Parcourir" onAction="#handleChooseImage"
                                style="-fx-background-color: #eef2ff; -fx-text-fill: #6366f1;
                                       -fx-font-weight: bold; -fx-font-size: 13px;
                                       -fx-background-radius: 12; -fx-padding: 11 18;
                                       -fx-border-color: #c7d2fe; -fx-border-width: 1;
                                       -fx-border-radius: 12; -fx-cursor: hand;"/>
                    </HBox>
                    <!-- Preview image -->
                    <VBox fx:id="imagePreviewBox" managed="false" visible="false"
                          style="-fx-background-color: #f8fafc; -fx-background-radius: 12;
                                 -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12;
                                 -fx-padding: 12;" spacing="8" alignment="CENTER_LEFT">
                        <Label text="Aperçu :" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
                        <ImageView fx:id="imagePreview" fitWidth="200" fitHeight="120"
                                   preserveRatio="true" smooth="true"/>
                    </VBox>
                </VBox>

                <!-- Fichier PDF -->
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Fichier PDF"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        <Label text="Optionnel"
                               style="-fx-background-color: #f8fafc; -fx-text-fill: #94a3b8;
                                      -fx-font-size: 11px; -fx-background-radius: 6; -fx-padding: 2 8;
                                      -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 6;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="pdfFileField"
                                   promptText="Cliquez sur Parcourir..." editable="false"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-radius: 12; -fx-border-radius: 12;
                                          -fx-border-color: #e2e8f0; -fx-border-width: 2;
                                          -fx-padding: 11 14; -fx-font-size: 13px; -fx-text-fill: #64748b;"/>
                        <Button text="📄  Parcourir" onAction="#handleChoosePdf"
                                style="-fx-background-color: #fff1f2; -fx-text-fill: #e11d48;
                                       -fx-font-weight: bold; -fx-font-size: 13px;
                                       -fx-background-radius: 12; -fx-padding: 11 18;
                                       -fx-border-color: #fecdd3; -fx-border-width: 1;
                                       -fx-border-radius: 12; -fx-cursor: hand;"/>
                    </HBox>
                    <!-- Info PDF existant en mode edit -->
                    <HBox fx:id="pdfExistingBox" managed="false" visible="false"
                          style="-fx-background-color: #eff6ff; -fx-background-radius: 10;
                                 -fx-border-color: #bfdbfe; -fx-border-width: 1; -fx-border-radius: 10;
                                 -fx-padding: 10 14;" alignment="CENTER_LEFT" spacing="10">
                        <Label text="📄" style="-fx-font-size: 20px;"/>
                        <VBox spacing="2">
                            <Label text="PDF déjà enregistré"
                                   style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #1d4ed8;"/>
                            <Label text="Laissez vide pour conserver le PDF actuel"
                                   style="-fx-font-size: 11px; -fx-text-fill: #3b82f6;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <Separator/>

                <!-- Boutons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="✕  Annuler" onAction="#handleRetour"
                            style="-fx-background-color: white; -fx-text-fill: #64748b;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-background-radius: 12; -fx-padding: 12 22;
                                   -fx-border-color: #cbd5e1; -fx-border-width: 2;
                                   -fx-border-radius: 12; -fx-cursor: hand;"/>
                    <Button fx:id="submitBtn" text="💾  Enregistrer" onAction="#handleSubmit"
                            style="-fx-background-color: linear-gradient(to right,#6366f1,#9333ea);
                                   -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;
                                   -fx-background-radius: 12; -fx-padding: 12 28; -fx-cursor: hand;"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
