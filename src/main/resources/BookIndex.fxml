<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="dev.eduplay.controllers.BookIndexController"
      style="-fx-background-color: #f1f5f9;" spacing="0">

    <!-- HEADER GRADIENT indigo/violet -->
    <HBox style="-fx-background-color: linear-gradient(to right,#6366f1,#9333ea);
                 -fx-padding: 28 32;" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="📚 Gestion des Ressources"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Explorez, recherchez et gérez votre collection de ressources"
                   style="-fx-font-size: 13px; -fx-text-fill: #c7d2fe;"/>
        </VBox>
        <Button text="＋  Nouvelle Ressource" onAction="#handleNouveauLivre"
                style="-fx-background-color: white; -fx-text-fill: #6366f1;
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-background-radius: 12; -fx-padding: 12 22; -fx-cursor: hand;"/>
    </HBox>

    <!-- BARRE DE RECHERCHE -->
    <HBox style="-fx-background-color: white; -fx-padding: 14 32;
                 -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="10">
        <TextField fx:id="searchField" promptText="🔍  Titre, auteur, résumé..."
                   style="-fx-background-radius: 10; -fx-border-radius: 10;
                          -fx-border-color: #cbd5e1; -fx-border-width: 2;
                          -fx-padding: 9 14; -fx-font-size: 13px;" prefWidth="260"/>
        <ComboBox fx:id="filterType" promptText="Type"
                  style="-fx-background-radius: 10; -fx-font-size: 13px;" prefWidth="130"/>
        <ComboBox fx:id="filterLanguage" promptText="Langue"
                  style="-fx-background-radius: 10; -fx-font-size: 13px;" prefWidth="120"/>
        <Button text="Rechercher" onAction="#handleSearch"
                style="-fx-background-color: linear-gradient(to right,#6366f1,#9333ea);
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 10; -fx-padding: 9 20; -fx-cursor: hand;"/>
        <Button text="Réinitialiser" onAction="#handleReset"
                style="-fx-background-color: white; -fx-text-fill: #64748b;
                       -fx-border-color: #cbd5e1; -fx-border-width: 2;
                       -fx-background-radius: 10; -fx-padding: 9 16; -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel"
               style="-fx-background-color: #f0fdf4; -fx-text-fill: #15803d;
                      -fx-font-weight: bold; -fx-font-size: 13px;
                      -fx-background-radius: 8; -fx-padding: 6 14;
                      -fx-border-color: #bbf7d0; -fx-border-width: 1; -fx-border-radius: 8;"/>
    </HBox>

    <!-- FLASH -->
    <HBox fx:id="flashBox" alignment="CENTER_LEFT" spacing="10"
          style="-fx-padding: 10 32;" managed="false" visible="false">
        <Label fx:id="flashLabel" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
    </HBox>

    <!-- CARTES -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: #f1f5f9;">
        <VBox style="-fx-padding: 24 32;">
            <FlowPane fx:id="cardsPane" hgap="24" vgap="24"
                      style="-fx-background-color: transparent;"/>
            <VBox fx:id="emptyState" alignment="CENTER" spacing="16"
                  style="-fx-padding: 80 0;" managed="false" visible="false">
                <Label text="📄" style="-fx-font-size: 64px;"/>
                <Label text="Aucune Ressource disponible"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                <Label text="Commencez à enrichir votre collection."
                       style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                <Button text="＋  Créer une Ressource" onAction="#handleNouveauLivre"
                        style="-fx-background-color: linear-gradient(to right,#6366f1,#9333ea);
                               -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
